# 复制本文件为 .env 并填写真实值。不要将 .env 提交到版本库。

BOT_TOKEN=

# 可选：机器人 @用户名（不要带 @）。配置后 Case Overview 长文折叠可在正文用可点击链接展开/收起；不配置则仅显示纯文字提示
# BOT_USERNAME=YourBotName

# 国内访问 Telegram 时常需要，例如: http://127.0.0.1:7890
HTTPS_PROXY=

# 逗号分隔多个 Telegram 用户 ID
ADMIN_IDS=

DB_HOST=localhost
DB_PORT=5432
DB_NAME=ic3_bot
DB_USER=postgres
DB_PASSWORD=

ETHERSCAN_KEY=
TRONGRID_API_KEY=
# 可选：某些环境 Tronscan 会 401；配置后统一调度层会自动用 TronGrid 兜底
# TRONSCAN_API_KEY=
LOCATIONIQ_API_KEY=
BREVO_API_KEY=

# 可选：/start 首页横幅 PNG 路径；默认项目根目录 ic3shuyen.png
# START_HOME_BANNER_IMAGE=

# 可选：签名与邮件
# SIGNATURE_SECRET_KEY=
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM_EMAIL=
# SMTP_FROM_NAME=
