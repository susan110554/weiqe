            await q.message.reply_text("❌ Case not found.")
            return
        status = c.get("status", "SUBMITTED")
        _stage_meta = {
            "SUBMITTED": ("⚪", "SUBMITTED",
                          "Your complaint has been successfully submitted."),
            "PENDING REVIEW": ("🟡", "PENDING REVIEW",
