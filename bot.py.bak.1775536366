            "For case details, use M03-CTS Case Tracking.\n\n"
            f"Auth Ref: <code>{AUTH_ID}</code>"
        )
        try:
            await ctx.bot.send_message(
                c["tg_user_id"],
                notify,
                parse_mode="HTML",
                reply_markup=kb_autopush_followup(case_no, None),
            )
            await q.message.reply_text(f"✅ Notification sent to UID {c['tg_user_id']}")
        except Exception as e:
            await q.message.reply_text(f"❌ Failed: {e}")
        return

    # ── Admin: evidence list → 发送证据图片/文件给管理员 ──────────────────────────
    if data.startswith("evlist|"):
        await q.answer()
        _, case_no = data.split("|", 1)
        evs = await db.get_evidences(case_no)
        if not evs:
            await q.message.reply_text("📁 No evidence files on record.")
            return
        admin_chat_id = q.message.chat_id
        await q.message.reply_text(
            f"📁 <b>Evidence Files — {case_no}</b>\n"
            f"Total: {len(evs)} file(s). Sending images/files below…",
            parse_mode="HTML",
        )
        for i, ev in enumerate(evs, 1):
            file_id = ev.get("file_id")
            if not file_id:
                await q.message.reply_text(
                    f"#{i} [{ev.get('file_type','?')}] {ev.get('file_name','')} — no file_id"
                )
                continue
            t = ev.get("uploaded_at")
            ts = t.strftime("%m-%d %H:%M") if t else ""
            caption = f"#{i} [{ev.get('file_type','')}] {ev.get('file_name','')} — {ts}"
            fname = (ev.get("file_name") or "").lower()
            try:
                if fname.endswith((".jpg", ".jpeg", ".png", ".gif", ".webp")) or (
                    ev.get("file_type") or ""
                ).startswith("EVM-01") or (ev.get("file_type") or "") == "IMAGE":
                    await ctx.bot.send_photo(
                        admin_chat_id, photo=file_id, caption=caption,
                    )
                else:
                    await ctx.bot.send_document(
                        admin_chat_id, document=file_id, caption=caption,
                    )
            except Exception:
                try:
                    await ctx.bot.send_document(
                        admin_chat_id, document=file_id, caption=caption,
                    )
                except Exception as e:
                    await q.message.reply_text(f"#{i} Failed to send: {ev.get('file_name','')} — {e}")
        return

    # ── Admin: 派遣探员 — 先输入探员显示名/编号，再输入电报 ID 或 @用户名 ──
    if data.startswith("assign|"):
        await q.answer()
        if not is_admin(update.effective_user.id):
            await q.message.reply_text("❌ 权限不足。")
            return
        _, case_no = data.split("|", 1)
        ctx.user_data["state"] = "AGENT_ASSIGN_INPUT"
        ctx.user_data["assign_agent_case"] = case_no
        ctx.user_data["assign_agent_code"] = None
        from bot_modules.i18n_admin import ASSIGN_AGENT_PROMPT
        await q.message.reply_text(
            ASSIGN_AGENT_PROMPT.format(case_no=case_no),
            parse_mode="HTML",
        )
        return

    # ── Admin: open liaison channel ─────────────────────
    if data.startswith("liaison_open|"):
        await q.answer()
        if not is_admin(update.effective_user.id):
            await q.message.reply_text("❌ Access Denied.")
            return
        _, case_no = data.split("|", 1)
        c = await db.get_case_by_no(case_no)
        _uid = c.get("tg_user_id") if c.get("tg_user_id") is not None else c.get("user_id")
        if not c or _uid is None:
            await q.message.reply_text("❌ Case not found or missing complainant UID.")
            return
        # 同一用户同时仅保留一条联络通道开启；先取消旧空闲任务再关库内标记
        for _open_cn in await db.list_open_liaison_case_nos_for_user(int(_uid)):
            cancel_liaison_idle_close_task(ctx.application, _open_cn)
        await db.close_all_liaison_for_tg_user(int(_uid))
        ok = await db.set_liaison(case_no, True)
        if ok and c:
            agent_code = _agent_mono(c.get("agent_code"))
            _tgt_open = int(c["tg_user_id"]) if c.get("tg_user_id") is not None else int(_uid)
            try:
                _idle_m = _liaison_idle_minutes_phrase()
                await ctx.bot.send_message(
                    _tgt_open,
                    "🏛 <b>SECURE LIAISON CHANNEL — NOW ACTIVE</b>\n"
                    "━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n\n"
                    f"🔖 Case: <code>{case_no}</code>\n"
                    f"👤 Assigned Agent: <code>{agent_code}</code>\n\n"
                    "⚡ <b>Communication Authorization Granted</b>\n\n"
                    "A secure communication channel has been opened\n"
                    "for this case under <b>28 C.F.R. Part 20</b>.\n\n"
                    "You may now send a text message directly below.\n"
                    "All transmissions are SHA-256 logged as federal\n"
                    "evidence per <b>FRE Rule 901</b>.\n\n"
                    f"⏳ <b>This channel will close automatically if there is no\n"
                    f"activity for {_idle_m}.</b> Any message from you or your\n"
                    "assigned agent resets this timer.\n\n"
                    f"<i>Auth Ref: <code>{AUTH_ID}</code></i>",
                    parse_mode="HTML")
            except Exception:
                pass
            schedule_liaison_idle_close(ctx.application, case_no, _tgt_open)
            await q.message.reply_text(
                f"✅ Liaison channel OPENED for <code>{case_no}</code>\n"
                f"Auto-closes after {_liaison_idle_minutes_phrase()} without activity.",
                parse_mode="HTML")
        else:
            await q.message.reply_text("❌ Failed to open channel.")
        return

    # ── Admin: close liaison channel ────────────────────
    if data.startswith("liaison_close|"):
        await q.answer()
        if not is_admin(update.effective_user.id):
            await q.message.reply_text("❌ Access Denied.")
            return
        _, case_no = data.split("|", 1)
        c = await db.get_case_by_no(case_no)
        _uid = c.get("tg_user_id") if c.get("tg_user_id") is not None else c.get("user_id")
        if not c or _uid is None:
            await q.message.reply_text("❌ Case not found or missing complainant UID.")
            return
        for _open_cn in await db.list_open_liaison_case_nos_for_user(int(_uid)):
            cancel_liaison_idle_close_task(ctx.application, _open_cn)
        n_closed = await db.close_all_liaison_for_tg_user(int(_uid))
        if n_closed > 0:
            try:
                tgt = int(c["tg_user_id"]) if c.get("tg_user_id") is not None else int(_uid)
                await ctx.bot.send_message(
                    tgt,
                    "🔒 <b>SECURE LIAISON — CHANNEL CLOSED</b>\n"
                    "━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n\n"
                    f"Case: <code>{case_no}</code>\n\n"
                    "The secure communication channel for this case\n"
                    "has been closed by the assigned agent.\n"
                    "All communications have been archived as\n"
                    "federal evidence records.\n\n"
                    f"<i>Auth Ref: <code>{AUTH_ID}</code></i>",
                    parse_mode="HTML")
            except Exception: pass
            await q.message.reply_text(f"🔒 Liaison channel CLOSED for <code>{case_no}</code>", parse_mode="HTML")
        else:
            await q.message.reply_text(
                "ℹ️ No open liaison channel for this complainant (already closed).",
                parse_mode="HTML",
            )
        return

    # ── Admin: compose agent message ────────────────────
    if data.startswith("agentmsg|"):
        await q.answer()
        if not is_admin(update.effective_user.id):
            await q.message.reply_text("❌ Access Denied.")
            return
        _, case_no = data.split("|", 1)
        c = await db.get_case_by_no(case_no)
        if not c:
            await q.message.reply_text(f"❌ Case not found: <code>{case_no}</code>", parse_mode="HTML")
            return
        complainant_uid = c.get("tg_user_id") or c.get("user_id")
        if complainant_uid is None:
            await q.message.reply_text("❌ This case has no complainant Telegram UID. Cannot send message.")
            return
        ctx.user_data["agent_compose_case"] = case_no
        ctx.user_data["state"] = "AGENT_COMPOSE"
        agent_code = _agent_mono(c.get("agent_code"))
        await q.message.reply_text(
            "SECURE LIAISON — COMPOSE MESSAGE\n"
            "━━━━━━━━━━━━━━━━━━\n"
            f"<code>CASE    : {case_no}</code>\n"
            f"<code>AGENT   : {agent_code}</code>\n"
            f"<code>TO      : UID {complainant_uid}</code>\n"
            "━━━━━━━━━━━━━━━━━━\n\n"
            "Type your reply below and send.\n"
            "It will be delivered as an official agent message.\n\n"
            "<i>All transmissions are SHA-256 logged per FRE Rule 901.</i>",
            parse_mode="HTML",
            reply_markup=InlineKeyboardMarkup([
                [InlineKeyboardButton(
                    "View Conversation",
                    callback_data=f"adm|liaison|view|{case_no}"
                )],
                [InlineKeyboardButton(
                    "Cancel",
                    callback_data=f"adm|case|{case_no}"
                )],
            ]))
        return

    if data.startswith("upload_set|"):
        _, case_no = data.split("|", 1)
        ctx.user_data["upload_case_no"] = case_no
        await q.message.reply_text(
            f"📤 Ready to upload to <code>{case_no}</code>\nSend your files now.",
            parse_mode="HTML")
        return

    # ── Liaison init: generate 60s auth token + agent link ──
    if data.startswith("liaison_init|"):
        _, case_no = data.split("|", 1)
        await q.answer("🔐 Generating authorization token...", show_alert=False)
        c = await db.get_case_by_no(case_no)
        if not c:
            await q.message.reply_text("❌ Case not found.")
            return
        sa = (c.get("agent_code") or "").strip()
        sa_mono = _agent_mono(sa or None)
        uid = update.effective_user.id

        # Generate one-time auth token (SHA-256 of case+uid+timestamp)
        import hashlib, time, asyncio
        token_seed = f"{case_no}|{uid}|{int(time.time())}"
        auth_token = hashlib.sha256(token_seed.encode()).hexdigest()[:16].upper()
        expires_ts = datetime.now() + timedelta(seconds=60)
        expires_str = expires_ts.strftime("%H:%M:%S UTC")

        # Log token issuance
        await db.log_audit(
            actor_type="SYSTEM", actor_id=str(uid),
            action="LIAISON_TOKEN_ISSUED",
            detail=f"case={case_no} agent={sa or '—'} token={auth_token} expires={expires_str}"
        )

        # Build Telegram deep link to admin (uses ADMIN_IDS[0] if set)
        agent_tg_link = None
        if ADMIN_IDS:
            # We use the bot's own username as relay — admin will see the token
            bot_info = await ctx.bot.get_me()
            start_param = f"liaison_{auth_token}"
            agent_tg_link = f"https://t.me/{bot_info.username}?start={start_param}"

        # Send auth token card
        token_msg = await q.message.reply_text(
            "<code>[IC3-ADRI] LIAISON AUTHORIZATION SYSTEM</code>\n"
            "<code>────────────────────────────────────</code>\n"
            f"<code>CASE ID    : {case_no}</code>\n"
            f"<code>AGENT      : {_agent_card_title(sa or None)}</code>\n"
            f"<code>TOKEN TYPE : ONE-TIME ACCESS KEY</code>\n"
            f"<code>EXPIRES    : {expires_str} (60 seconds)</code>\n"
            "<code>────────────────────────────────────</code>\n\n"
            "🔑 <b>AUTHORIZATION TOKEN:</b>\n"
            f"<code>  {auth_token[:4]}-{auth_token[4:8]}-{auth_token[8:12]}-{auth_token[12:16]}</code>\n\n"
            "<code>[SYSTEM]: Link Authentication Successful.</code>\n"
            f"<code>Liaison Node: {sa_mono} (Active)</code>\n\n"
            "Please click below to start secure messaging.\n"
            "<i>⚠️ This token and link expire in 60 seconds.</i>",
            parse_mode="HTML",
            reply_markup=InlineKeyboardMarkup([
                *([[InlineKeyboardButton(
                    f"🛡️ CONNECT TO AGENT ({sa_mono})" if sa else "🛡️ CONNECT TO AGENT",
                    url=agent_tg_link
                )]] if agent_tg_link else []),
                [InlineKeyboardButton("❌ Cancel", callback_data="M03")],
            ])
        )

        # Auto-delete token card after 60 seconds
        async def _expire_token():
            await asyncio.sleep(60)
            try:
                await token_msg.edit_text(
                    "<code>[IC3-ADRI] TOKEN EXPIRED</code>\n"
                    "<code>────────────────────────────────────</code>\n"
                    f"<code>CASE ID : {case_no}</code>\n"
                    f"<code>STATUS  : AUTHORIZATION TOKEN INVALIDATED</code>\n"
                    f"<code>REASON  : 60-second session window closed.</code>\n"
                    "<code>────────────────────────────────────</code>\n"
                    "<i>Please return to Status Inquiry to\n"
                    "generate a new authorization token.</i>",
                    parse_mode="HTML",
                    reply_markup=InlineKeyboardMarkup([[
                        InlineKeyboardButton("🔄 Request New Token", callback_data=f"liaison_init|{case_no}")
                    ]])
                )
            except Exception:
                pass
        asyncio.create_task(_expire_token())
        return

    # ── Liaison info: show active channel card to user ──
    # ── Liaison conversation thread view (admin) ────────
    if data.startswith("adm|liaison|view|"):
        await q.answer()
        if not is_admin(update.effective_user.id):
            await q.message.reply_text("❌ Access Denied.")
            return
        parts = data.split("|", 3)
        case_no = parts[3] if len(parts) == 4 else ""
        msgs = await db.get_liaison_messages(case_no, limit=20)
        if not msgs:
            await q.message.reply_text(
                f"No conversation records found for <code>{case_no}</code>.",
                parse_mode="HTML",
            )
            return
        sep = "────────────────────────────────────"
        lines = [
            "SECURE LIAISON — CONVERSATION THREAD",
            "━━━━━━━━━━━━━━━━━━",
            f"<code>CASE : {case_no}</code>",
            "━━━━━━━━━━━━━━━━━━",
            "",
        ]
        for m in reversed(msgs):
            sender = (m.get("sender_type") or "SYSTEM").upper()
            ts = str(m.get("created_at") or "")[:16].replace("T", " ")
            txt = (m.get("message_text") or "").strip()
            if sender == "USER":
                prefix = "USER"
            elif sender in ("ADMIN", "AGENT"):
                prefix = "AGENT"
            else:
                prefix = "SYSTEM"
            lines.append(f"<b>[{prefix}]</b>  <i>{ts}</i>")
            lines.append(f"{txt}")
            lines.append(sep)
        await q.message.reply_text(
            "\n".join(lines),
            parse_mode="HTML",
            reply_markup=InlineKeyboardMarkup([
                [InlineKeyboardButton(
                    "Reply as Agent",
                    callback_data=f"agentmsg|{case_no}"
                )],
                [InlineKeyboardButton(
                    "Close Channel",
                    callback_data=f"liaison_close|{case_no}"
                )],
            ]),
        )
        return

    if data.startswith("liaison_info|"):
        _, case_no = data.split("|", 1)
        c = await db.get_case_by_no(case_no)
        if not c or not c.get("is_liaison_open"):
            await q.answer("⚠️ Channel is not currently active.", show_alert=True)
            return
        sa = (c.get("agent_code") or "").strip()
        sa_mono = _agent_mono(sa or None)
        await q.message.reply_text(
            "🛰️ <b>[SECURE LIAISON NODE — ACTIVE]</b>\n"
            "────────────────────\n"
            f"<code>CASE ID    : {case_no}</code>\n"
            f"<code>AGENT      : {_agent_card_title(sa or None)}</code>\n"
            f"<code>CHANNEL    : OPEN / ENCRYPTED</code>\n"
            f"<code>AUTO-CLOSE : after {_liaison_idle_minutes_phrase()} without activity</code>\n"
            "────────────────────\n"
            "✅ <b>Authentication Successful.</b>\n\n"
            "You are now authorized to communicate directly\n"
            f"with <b>{sa_mono}</b> via this interface.\n\n"
            "<b>Instructions:</b>\n"
            "• Simply <b>type your message</b> in this chat.\n"
            "• All transmissions are SHA-256 logged as\n"
            "  federal evidence per <b>FRE Rule 901</b>.\n"
            f"• The channel auto-closes after {_liaison_idle_minutes_phrase()} with no\n"
            "  messages from you or the agent; sending a message resets the timer.\n"
            "────────────────────\n"
            "<i>⚠️ Do not share sensitive financial credentials\n"
            "in this channel. Authorized agents will never\n"
            "request wallet keys or seed phrases.</i>",
            parse_mode="HTML",
        )
        return

    # ── Fallback: answer any unhandled callback to clear the spinner ──
    await q.answer()


# ══════════════════════════════════════════════════════
# SHARED HELPERS
# ══════════════════════════════════════════════════════
import hashlib as _hashlib


def _agent_mono(agent_code: str | None) -> str:
    s = (agent_code or "").strip()
    return s if s else "—"


def _liaison_btn_label(agent_code: str | None) -> str:
    s = (agent_code or "").strip()
    return f"🛰️ INITIALIZE SECURE LIAISON ({s})" if s else "🛰️ INITIALIZE SECURE LIAISON"


def _assigned_timeline_detail(agent_code: str | None) -> str:
    s = (agent_code or "").strip()
    if s:
        return f"Assigned: Specialist ({s})."
    return "Specialist assignment pending."


def _agent_card_title(agent_code: str | None) -> str:
    s = (agent_code or "").strip()
    return f"Case specialist ({s})" if s else "Case specialist (pending)"


def _status_sha256(c: dict) -> str:
    """Generate a deterministic SHA-256 fingerprint for this case's current state."""
    payload = (
        f"{c.get('case_no','')}|"
        f"{c.get('status','')}|"
        f"{c.get('agent_code','NULL')}|"
        f"{c.get('updated_at','')}"
    )
    return _hashlib.sha256(payload.encode()).hexdigest()


async def _resolve_user_case_for_m03(ctx: ContextTypes.DEFAULT_TYPE, uid: int) -> dict | None:
    """Resolve the same case as M03-CTS-02 (last_case_id or most recent case for this Telegram user)."""
    last_case_id = ctx.user_data.get("last_case_id")
    if last_case_id:
        c = await db.get_case_by_no(last_case_id)
        if c:
            return c
    all_cases = await db.get_recent_cases(50)
    for rc in all_cases:
        if rc.get("tg_user_id") == uid:
            return rc
    return None


async def _kb_m03_for_user(ctx: ContextTypes.DEFAULT_TYPE, uid: int):
    """M03 menu keyboard with CTS-03 unlock derived from DB case status."""
    case = await _resolve_user_case_for_m03(ctx, uid)
    return kb_m03(user_data=ctx.user_data, case=case)


async def _cmp_p9_verify_compliance_flow(
    q,
    ctx: ContextTypes.DEFAULT_TYPE,
    case_no: str,
    c: dict,
) -> None:
    """P9：模拟扫描 → 约 4s 后编辑为 HOLD 警告 + VIEW COMPLIANCE DETAILS。"""
    import asyncio

    ovr = effective_cmp_overrides(c)
    p1 = build_p9_compliance_scan_phase1(case_no, ovr)
    scan_msg = await q.message.reply_text(p1, parse_mode="HTML")
    await asyncio.sleep(4.0)
    p2 = build_p9_compliance_scan_phase2(case_no, ovr)
    kb2 = InlineKeyboardMarkup(
        [
            [
                InlineKeyboardButton(
                    "🔓 VIEW COMPLIANCE DETAILS",
                    callback_data=f"cmp|p9compdet|{case_no}",
                )
            ],
        ]
    )
    try:
        await scan_msg.edit_text(p2, parse_mode="HTML", reply_markup=kb2)
    except Exception:
        logger.exception("[cmp] p9 scan phase2 edit")
        await q.message.reply_text(p2, parse_mode="HTML", reply_markup=kb2)


async def _cmp_p9_compdet_loading_flow(
    q,
    ctx: ContextTypes.DEFAULT_TYPE,
    case_no: str,
    c: dict,
) -> None:
    """P9：加载动画 → 约 10 秒后推送 P10（四段间隔各 2.5s）。"""
    import asyncio

    _step = 2.5  # 4×2.5s = 10s 自首条加载消息至发出 P10
    m = effective_cmp_overrides(c)
    load_msg = await q.message.reply_text(
        build_p9_compliance_loading_text(20), parse_mode="HTML"
    )
    await asyncio.sleep(_step)
    try:
        await load_msg.edit_text(build_p9_compliance_loading_text(50), parse_mode="HTML")
    except Exception:
        logger.exception("[cmp] p9 load 50")
    await asyncio.sleep(_step)
    try:
        await load_msg.edit_text(build_p9_compliance_loading_text(80), parse_mode="HTML")
    except Exception:
        logger.exception("[cmp] p9 load 80")
    await asyncio.sleep(_step)
    try:
        await load_msg.edit_text(build_p9_compliance_loading_text(100), parse_mode="HTML")
    except Exception:
        logger.exception("[cmp] p9 load 100")
    await asyncio.sleep(_step)
    b10, kb10 = build_p10_sanction_push(case_no, m, c)
    await q.message.reply_text(b10, parse_mode="HTML", reply_markup=kb10)


async def handle_cmp_callback(update: Update, ctx: ContextTypes.DEFAULT_TYPE, data: str):
    """案件管理推送：refresh / doj / p5 身份屏 / p5std EVM-01 / c|slug| m|slug| / p7wal p8wal 等"""
    q = update.callback_query
    op, slug, case_no = _cmp_parse(data)
    if op is None or not case_no:
        await q.answer()
        return
    uid = update.effective_user.id
    if not await db.verify_case_ownership(case_no, uid):
        await q.answer("Access denied for this case.", show_alert=True)
        return

    if op == "refresh":
        await q.answer()
        c = await db.get_case_by_no(case_no)
        if not c:
            await q.message.reply_text("❌ Case not found.", parse_mode="HTML")
            return
        await _send_case_status(q.message, c)
        return

    if op == "doj":
        await q.answer()
        body, kb = build_doj_forfeiture_notice()
        await q.message.reply_text(body, parse_mode="HTML", reply_markup=kb)
        return

    if op == "p5":
        await q.answer()
        try:
            await on_user_opens_p5(case_no)
        except Exception:
            logger.exception("[auto-progress] on_user_opens_p5 case=%s", case_no)
        body, kb = build_p5_identity_push(case_no)
        await q.message.reply_text(body, parse_mode="HTML", reply_markup=kb)
        return

    if op == "p5std":
        await q.answer()
        try:
            await on_p5_standard_chosen(case_no, ctx.application)
        except Exception:
            logger.exception("[auto-progress] on_p5_standard_chosen case=%s", case_no)
        ctx.user_data["last_case_id"] = case_no
        ctx.user_data["upload_case_no"] = case_no
        ctx.user_data["evid_auth_case"] = case_no
        ctx.user_data["upload_evm_type"] = "EVM-01"
        sep = "────────────────────"
        txt = (
            "<b>STANDARD PETITION — IDENTITY RECORDS</b>\n\n"
            "<code>[EVM: COMPLAINANT IDENTITY RECORDS]</code>\n"
            f"<code>{sep}</code>\n"
            "<code>MODULE     : EVM-01 · IDENTITY DOCUMENTS</code>\n"
            "<code>PROTOCOL   : FORENSIC INTAKE / SHA-256 VERIFIED</code>\n"
            f"<code>UID        : {uid}</code>\n"
            f"<code>CASE ID    : {case_no}</code>\n"
            "<code>STATUS     : INITIALIZING PROTOCOL...</code>\n"
            f"<code>{sep}</code>\n\n"
            "📍 <b>ACTION REQUIRED:</b>\n"
            "Please select your document type to begin the forensic scan:"
        )
        kb_doc_type = InlineKeyboardMarkup([
            [
                InlineKeyboardButton("Passport", callback_data="EVM-01-DOC|PASSPORT"),
                InlineKeyboardButton("Driver's License", callback_data="EVM-01-DOC|DL"),
                InlineKeyboardButton("National ID", callback_data="EVM-01-DOC|NID"),
            ],
        ])
        await q.message.reply_text(txt, parse_mode="HTML", reply_markup=kb_doc_type)
        return

    if op == "p5pri":
        await q.answer()
        await show_authorization_screen(
            update,
            ctx,
            case_no=case_no,
            payment_kind="p5_priority",
            show_free_cancel=True,
        )
        return

    if op == "p9contract":
        await q.answer()
        c = await db.get_case_by_no(case_no)
        raw_o = raw_case_cmp_overrides(c)
        if not raw_o.get("p9_federal_contract_by_admin"):
            await q.message.reply_text(
                "⚠️ <b>Contract address not available</b>\n\n"
                "The administrator has not configured the official contract address for your case yet.\n"
                "Please check back later or contact support.",
                parse_mode="HTML",
            )
            return
        m = effective_cmp_overrides(c)
        fac = str(m.get("p9_federal_contract_address") or "").strip()
        if not fac:
            await q.message.reply_text(
                "⚠️ Contract address is missing. Please contact support.",
                parse_mode="HTML",
            )
            return
        await q.message.reply_text(
            "📋 <b>Official Asset Contract Address</b> (TRC-20)\n\n"
            f"<code>{html.escape(fac)}</code>\n\n"
            "<i>Next message is plain text — tap it and use Select All to copy.</i>",
            parse_mode="HTML",
        )
        await q.message.reply_text(fac)
        return

    if op == "p9verify":
        await q.answer()
        c = await db.get_case_by_no(case_no)
        if not c:
            await q.message.reply_text("❌ Case not found.", parse_mode="HTML")
            return
        await _cmp_p9_verify_compliance_flow(q, ctx, case_no, c)
        return

    if op == "p9compdet":
        await q.answer()
        c = await db.get_case_by_no(case_no)
        if not c:
            await q.message.reply_text("❌ Case not found.", parse_mode="HTML")
            return
        await _cmp_p9_compdet_loading_flow(q, ctx, case_no, c)
        return

    if op == "p8wal":
        await q.answer()
        ctx.user_data["state"] = "CMP_P8_AWAIT_ADDR"
        ctx.user_data["cmp_trc20_case"] = case_no
        ctx.user_data["cmp_trc20_kind"] = "p8wal"
        ctx.user_data.pop("cmp_p8_pending_addr", None)
        await _send_p8_wallet_flow_phase1(q.message, case_no)
        return

    if op == "p7wal":
        await q.answer()
        ctx.user_data["state"] = "CMP_AWAIT_TRC20"
        ctx.user_data["cmp_trc20_case"] = case_no
        ctx.user_data["cmp_trc20_kind"] = "p7wal"
        await q.message.reply_text(
            "📝 <b>TRC-20 (USDT) wallet address</b>\n"
            "━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n\n"
            "Send a single line containing your <b>non-custodial</b>\n"
            "TRC-20 USDT address (starts with <code>T</code>, 34 chars).\n\n"
            f"Case: <code>{case_no}</code>\n\n"
            "<i>CEX deposit addresses are not accepted.</i>",
            parse_mode="HTML",
        )
        return

    if op in ("p8try", "p8edit"):
        await q.answer()
        ctx.user_data["state"] = "CMP_P8_AWAIT_ADDR"
        ctx.user_data["cmp_trc20_case"] = case_no
        ctx.user_data["cmp_trc20_kind"] = "p8wal"
        ctx.user_data.pop("cmp_p8_pending_addr", None)
        await _send_p8_wallet_flow_phase1(q.message, case_no)
        return

    if op == "p8link":
        await q.answer()
        if ctx.user_data.get("state") != "CMP_P8_AWAIT_CONFIRM":
            await q.message.reply_text(
                "Session expired. Open <b>Submit Wallet Address</b> from your P8 case card again.",
                parse_mode="HTML",
            )
            return
        if (ctx.user_data.get("cmp_trc20_case") or "").strip() != case_no:
            await q.message.reply_text(
                "Case mismatch. Please start again from Case Tracking.",
                parse_mode="HTML",
            )
            return
        addr = (ctx.user_data.get("cmp_p8_pending_addr") or "").strip()
        if not _looks_trc20_usdt_addr(addr):
            ctx.user_data.pop("state", None)
            ctx.user_data.pop("cmp_p8_pending_addr", None)
            await q.message.reply_text(
                "Invalid pending address. Please open <b>Submit Wallet Address</b> again.",
                parse_mode="HTML",
            )
            return
        uid = q.from_user.id if q.from_user else 0
        if not await db.verify_case_ownership(case_no, uid):
            await q.message.reply_text("Access denied for this case.", parse_mode="HTML")
            return
        await _finalize_trc20_wallet_submission(
            q.message,
            ctx,
            case_no=case_no,
            addr=addr,
            kind="p8wal",
            uid=uid,
            p8_success_ui=True,
        )
        return

    if op == "c" and slug:
        cfg = contact_slug_config(slug)
        if not cfg:
            await q.answer("Unknown contact.", show_alert=True)
            return
        await q.answer()
        sub_ts = format_submitted_ts_utc_now()
        body, kb = build_agent_secure_contact_panel(slug, case_no, sub_ts)
        await q.message.reply_text(body, parse_mode="HTML", reply_markup=kb)
        return

    if op == "m" and slug:
        cfg = contact_slug_config(slug)
        if not cfg:
            await q.answer("Unknown contact.", show_alert=True)
            return
        await q.answer()
        ctx.user_data["state"] = "CMP_MSG_CASE_AGENT"
        ctx.user_data["cmp_contact_slug"] = slug.strip().lower()
        ctx.user_data["cmp_contact_case"] = case_no
        await q.message.reply_text(
            build_agent_compose_prompt(slug),
            parse_mode="HTML",
        )
        return

    if op == "wilson":
        await q.answer()
        sub_ts = format_submitted_ts_utc_now()
        body, kb = build_agent_secure_contact_panel("wilson", case_no, sub_ts)
        await q.message.reply_text(body, parse_mode="HTML", reply_markup=kb)
        return

    if op == "wilson_msg":
        await q.answer()
        ctx.user_data["state"] = "CMP_MSG_CASE_AGENT"
        ctx.user_data["cmp_contact_slug"] = "wilson"
        ctx.user_data["cmp_contact_case"] = case_no
        await q.message.reply_text(
            build_agent_compose_prompt("wilson"),
            parse_mode="HTML",
        )
        return

    if op == "p10pay":
        await q.answer()
        addr = next_trc20_deposit_address()
        if not addr:
            await q.message.reply_text(
                "❌ <b>Payment system unavailable</b>\n\n"
                "The USDT deposit pool is not configured.\n"
                "Please set <code>CRYPTOPAY_TRC20_POOL</code> in the server environment.",
                parse_mode="HTML",
            )
            return
        ctx.user_data["p10_pay_reserved"] = {"case_no": case_no, "addr": addr}
        c = await db.get_case_by_no(case_no)
        if not c:
            await q.message.reply_text("❌ Case not found.", parse_mode="HTML")
            return
        ovr = effective_cmp_overrides(c)
        body, kb = build_p10_chainalysis_authorization_panel(
            case_no, ovr, c, deposit_address=addr
        )
        await q.message.reply_text(body, parse_mode="HTML", reply_markup=kb)
        png = wallet_address_to_qr_png(addr)
        if png:
            await q.message.reply_photo(
                photo=png,
                caption=(
                    "<b>TRC20 (USDT) — deposit address</b>\n\n"
                    f"<code>{html.escape(addr)}</code>\n\n"
                    "<i>Long-press the address to copy. If your wallet supports a MEMO/Tag, use the "
                    "reference from the agreement above.</i>"
                ),
                parse_mode="HTML",
            )
        else:
            await q.message.reply_text(
                f"<b>Deposit address (TRC20 USDT)</b>\n\n<code>{html.escape(addr)}</code>",
                parse_mode="HTML",
            )
        return

    if op == "p10agree":
        await q.answer()
        slot = ctx.user_data.get("p10_pay_reserved") or {}
        reserved = (
            (slot.get("addr") or "").strip()
            if (slot.get("case_no") or "") == case_no
            else ""
        )
        await open_portal_for_case(
            q,
            ctx,
            case_no=case_no,
            payment_kind="p10_pay",
            uid=uid,
            deposit_address=reserved or None,
        )
        ctx.user_data.pop("p10_pay_reserved", None)
        return

    if op == "p10authcancel":
        await q.answer("Cancelled.")
        ctx.user_data.pop("p10_pay_reserved", None)
        try:
            await q.message.delete()
        except Exception:
            pass
        return

    if op == "p10pdf":
        await q.answer()
        c = await db.get_case_by_no(case_no)
        if not c:
            await q.message.reply_text("❌ Case not found.", parse_mode="HTML")
            return
        slot = ctx.user_data.get("p10_pay_reserved") or {}
        addr = (
            (slot.get("addr") or "").strip()
            if (slot.get("case_no") or "") == case_no
            else ""
        )
        if not addr:
            addr = (peek_trc20_deposit_address() or "").strip()
        if not addr:
            await q.message.reply_text(
                "❌ <b>TRC20 pool not configured</b>\n\n"
                "Set <code>CRYPTOPAY_TRC20_POOL</code> in the environment, or open "
                "<b>Execute Contract Fee</b> first so the deposit address is reserved.",
                parse_mode="HTML",
            )
            return
        ids = p10_chainalysis_reference_ids(case_no)
        contract_no = os.getenv(
            "CASE_P10_CHAINALYSIS_CONTRACT_NO", "DOJ-2024-BC-7829"
        )
        try:
            from bot_modules.receipt_pdf import generate_p10_service_agreement_pdf

            pdf_bytes = generate_p10_service_agreement_pdf(
                c,
                deposit_address=addr,
                memo=ids["memo"],
                service_order=ids["service_order"],
                contract_no=contract_no.strip(),
            )
            fn = f"ServiceAuthorization_{case_no.replace('/', '-')}.pdf"
            await q.message.reply_document(
                document=_io.BytesIO(pdf_bytes),
                filename=fn,
                caption=(
                    "📄 <b>Service Authorization</b> (same layout as payment receipt; "
                    "multi-line fees)"
                ),
                parse_mode="HTML",
            )
        except Exception:
            logger.exception("[cmp] p10pdf generation case=%s", case_no)
            await q.message.reply_text(
                "❌ PDF 生成失败，请确认已安装 <code>reportlab</code> 后重试。",
                parse_mode="HTML",
            )
        return

    if op == "p10email":
        await q.answer(
            "Use your case email or open “Contact Officer Taylor” from the compliance screen for delivery options.",
            show_alert=True,
        )
        return

    if op == "p11pay":
        await q.answer()
        addr = next_trc20_deposit_address()
        if not addr:
            await q.message.reply_text(
                "❌ <b>Payment system unavailable</b>\n\n"
                "The USDT deposit pool is not configured.\n"
                "Please set <code>CRYPTOPAY_TRC20_POOL</code> in the server environment.",
                parse_mode="HTML",
            )
            return
        ctx.user_data["p11_pay_reserved"] = {"case_no": case_no, "addr": addr}
        c = await db.get_case_by_no(case_no)
        if not c:
            await q.message.reply_text("❌ Case not found.", parse_mode="HTML")
            return
        ovr = effective_cmp_overrides(c)
        body, kb = build_p11_marshals_authorization_panel(
            case_no, ovr, c, deposit_address=addr
        )
        await q.message.reply_text(body, parse_mode="HTML", reply_markup=kb)
        png = wallet_address_to_qr_png(addr)
        if png:
            await q.message.reply_photo(
                photo=png,
                caption=(
                    "<b>TRC20 (USDT) — Federal Escrow deposit address</b>\n\n"
                    f"<code>{html.escape(addr)}</code>\n\n"
                    "<i>Long-press the address to copy. If your wallet supports a MEMO/Tag, use "
                    "<code>WITHDRAWAL-AUTH-…</code> from the agreement above.</i>"
                ),
                parse_mode="HTML",
            )
        else:
            await q.message.reply_text(
                f"<b>Deposit address (TRC20 USDT)</b>\n\n<code>{html.escape(addr)}</code>",
                parse_mode="HTML",
            )
        return

    if op == "p11agree":
        await q.answer()
        slot = ctx.user_data.get("p11_pay_reserved") or {}
        reserved = (
            (slot.get("addr") or "").strip()
            if (slot.get("case_no") or "") == case_no
            else ""
        )
        await open_portal_for_case(
            q,
            ctx,
            case_no=case_no,
            payment_kind="p11_pay",
            uid=uid,
            deposit_address=reserved or None,
        )
        ctx.user_data.pop("p11_pay_reserved", None)
        return

    if op == "p11authcancel":
        await q.answer("Cancelled.")
        ctx.user_data.pop("p11_pay_reserved", None)
        try:
            await q.message.delete()
        except Exception:
            pass
        return

    if op == "p11pdf":
        await q.answer()
        c = await db.get_case_by_no(case_no)
        if not c:
            await q.message.reply_text("❌ Case not found.", parse_mode="HTML")
            return
        slot = ctx.user_data.get("p11_pay_reserved") or {}
        addr = (
            (slot.get("addr") or "").strip()
            if (slot.get("case_no") or "") == case_no
            else ""
        )
        if not addr:
            addr = (peek_trc20_deposit_address() or "").strip()
        if not addr:
            await q.message.reply_text(
                "❌ <b>TRC20 pool not configured</b>\n\n"
                "Set <code>CRYPTOPAY_TRC20_POOL</code> in the environment, or open "
                "<b>Authorize Withdrawal</b> first so the deposit address is reserved.",
                parse_mode="HTML",
            )
            return
        ids = p11_withdrawal_reference_ids(case_no)
        suffix = ids["suffix"]
        escrow_display = os.getenv(
            "CASE_P11_ESCROW_DISPLAY",
            f"Federal Escrow Account #USMS-{suffix}",
        ).strip()
        contractor_id = os.getenv("CASE_P11_USMS_CONTRACTOR_ID", "FC-2024-VAL-8821").strip()
        try:
            from bot_modules.receipt_pdf import generate_p11_marshals_service_agreement_pdf

            pdf_bytes = generate_p11_marshals_service_agreement_pdf(
                c,
                deposit_address=addr,
                memo=ids["memo"],
                escrow_display=escrow_display,
                contractor_id=contractor_id,
            )
            fn = f"WithdrawalServiceAgreement_{case_no.replace('/', '-')}.pdf"
            await q.message.reply_document(
                document=_io.BytesIO(pdf_bytes),
                filename=fn,
                caption="📄 <b>Withdrawal authorization service agreement</b>",
                parse_mode="HTML",
            )
        except Exception:
            logger.exception("[cmp] p11pdf generation case=%s", case_no)
            await q.message.reply_text(
                "❌ PDF 生成失败，请确认已安装 <code>reportlab</code> 后重试。",
                parse_mode="HTML",
            )
        return

    if op == "p11email":
        await q.answer(
            "Use your case email or contact the assigned Financial Officer for delivery options.",
            show_alert=True,
        )
        return

    if op == "p12pay":
        await q.answer()
        await show_authorization_screen(
            update,
            ctx,
            case_no=case_no,
            payment_kind="p12_pay",
            show_free_cancel=False,
        )
        return

    await q.answer()


def _build_status_card(c: dict) -> tuple[str, "InlineKeyboardMarkup"]:
    """Return (message_text, keyboard) for a case status card."""
    case_no    = c.get("case_no", "N/A")
    status     = c.get("status", "SUBMITTED")
    agent_code = c.get("agent_code") or None
    liaison_open = bool(c.get("is_liaison_open"))
    created_at = c.get("created_at")
    updated_at = c.get("updated_at") or created_at
    filed_ts   = created_at.strftime("%Y-%m-%d %H:%M") if created_at else "N/A"
    updated_ts = updated_at.strftime("%Y-%m-%d %H:%M") if updated_at else "N/A"
    sha        = _status_sha256(c)

    # 通用 Case Tracking 菜单键盘（附带 PDF 与 CTS 子菜单）
    def _cts_keyboard(pdf_label: str = "📂 Download PDF Certificate") -> "InlineKeyboardMarkup":
        kb_m = kb_m03(case=c, user_data=None)
        rows = [[InlineKeyboardButton(pdf_label, callback_data=f"pdf|{case_no}")]]
        rows.extend(list(kb_m.inline_keyboard))
        return InlineKeyboardMarkup(rows)

    # ── Per-stage templates（案件管理推送模块 P1–P4）────────────────
    if status in ("SUBMITTED", "Pending Initial Review", "待初步审核",
                  "Pending", "PENDING"):
        body, kb = build_p1_push(case_no, format_case_date_utc(created_at))

    elif status in ("VALIDATING", "PENDING REVIEW"):
        body, kb = build_p2_push(case_no, format_case_date_utc(updated_at))

    elif status in ("UNDER REVIEW", "Under Review", "Case Accepted", "CASE ACCEPTED"):
        body, kb = build_p3_push(case_no, format_case_date_utc(updated_at))

    elif status in ("REFERRED", "REFERRED TO LAW ENFORCEMENT", "Processing Complete"):
        body, kb = build_p4_push(case_no, format_case_date_utc(updated_at))

    elif _cmp_status_matches(status, _CMP_P5_STATUSES):
        body, kb = build_p5_identity_push(case_no)

    elif _cmp_status_matches(status, _CMP_P6_STATUSES):
        body, kb = build_p6_preliminary_push(case_no, c)

    elif _cmp_status_matches(status, _CMP_P7_STATUSES):
        body, kb = build_p7_asset_tracing_push(case_no)

    elif _cmp_status_matches(status, _CMP_P8_STATUSES):
        body, kb = build_p8_legal_push(case_no)

    elif _cmp_status_matches(status, _CMP_P9_STATUSES):
        ovr = effective_cmp_overrides(c)
        body, kb = build_p9_disbursement_push(case_no, ovr)

    elif _cmp_status_matches(status, _CMP_P10_STATUSES):
        ovr = effective_cmp_overrides(c)
        body, kb = build_p10_sanction_push(case_no, ovr, c)

    elif _cmp_status_matches(status, _CMP_P11_STATUSES):
        body, kb = build_p11_protocol_push(case_no, c)

    elif _cmp_status_matches(status, _CMP_P12_STATUSES):
        ovr = effective_cmp_overrides(c)
        body, kb = build_p12_final_auth_push(case_no, ovr)

    elif status in ("CLOSED", "Case Closed"):
        body = (
            "📁 <b>[FINAL DISPOSITION: ARCHIVED]</b>\n"
            "────────────────────\n"
            f"<code>CASE ID   : {case_no}</code>\n"
            f"<code>STATUS    : ACTIONED / CLOSED</code>\n"
            f"<code>TIMESTAMP : {updated_ts} UTC</code>\n"
            "────────────────────\n"
            "<b>FINAL SUMMARY:</b>\n"
            "<code>Case closed. Investigative findings</code>\n"
            "<code>have been indexed for federal audit.</code>\n"
            "────────────────────\n"
            "<b>SECURITY NOTICE:</b>\n"
            "<code>All communication logs have been SEALED</code>\n"
            "<code>and PURGED from the active buffer.</code>\n"
            "<code>This case record is now READ-ONLY.</code>\n"
            "────────────────────\n"
            f"<code>🔐 STATE-HASH (SHA-256):</code>\n"
            f"<code>{sha[:32]}…</code>"
        )
        kb = _cts_keyboard(pdf_label="📂 Download Final PDF")

    else:
        # Fallback for unknown status
        body = (
            "🔎 <b>[CASE STATUS RECORD]</b>\n"
            "────────────────────\n"
            f"<code>CASE ID  : {case_no}</code>\n"
            f"<code>STATUS   : {status}</code>\n"
            f"<code>UPDATED  : {updated_ts} UTC</code>\n"
            "────────────────────\n"
            f"<code>🔐 STATE-HASH (SHA-256):</code>\n"
            f"<code>{sha[:32]}…</code>"
        )
        kb = _cts_keyboard(pdf_label="📂 Download PDF")

    return body, kb


async def _send_case_status(target, c: dict):
    """Show loading animation then deliver status card."""
    import asyncio
    # Step 1: authentication animation
    auth_msg = await target.reply_text(
        "<code>[IC3-NODE] Authenticating Secure Link...</code>\n"
        "<code>▓░░░░░░░░░  10%  — Verifying case ID...</code>",
        parse_mode="HTML"
    )
    await asyncio.sleep(0.8)
    try:
        await auth_msg.edit_text(
            "<code>[IC3-NODE] Authenticating Secure Link...</code>\n"
            "<code>▓▓▓▓░░░░░░  45%  — Decrypting record...</code>",
            parse_mode="HTML"
        )
    except Exception: pass
    await asyncio.sleep(0.8)
    try:
        await auth_msg.edit_text(
            "<code>[IC3-NODE] Authenticating Secure Link...</code>\n"
            "<code>▓▓▓▓▓▓▓▓▓░  90%  — Generating state hash...</code>",
            parse_mode="HTML"
        )
    except Exception: pass
    await asyncio.sleep(0.6)
    try:
        await auth_msg.delete()
    except Exception: pass

    # Step 2: deliver status card
    body, kb = _build_status_card(c)
    await target.reply_text(body, parse_mode="HTML", reply_markup=kb)
    st = (c.get("status") or "")
    if _cmp_status_matches(st, _CMP_P9_STATUSES):
        m_ov = effective_cmp_overrides(c)
        wal = str(m_ov.get("p8_submitted_wallet") or "").strip()
        png = wallet_address_to_qr_png(wal) if wal else None
        if png:
            try:
                await target.reply_photo(
                    photo=InputFile(_io.BytesIO(png), filename="destination_wallet_qr.png"),
                    caption=(
                        "📱 <b>Destination wallet (QR)</b>\n\n"
                        f"<code>{html.escape(wal)}</code>\n\n"
                        "<i>Scan to verify it matches the address in the card above.</i>"
                    ),
                    parse_mode="HTML",
                )
            except Exception:
                logger.exception("P9 wallet QR reply_photo failed")


async def _send_cts_query_prompt(target, ctx: ContextTypes.DEFAULT_TYPE):
    """
    显示 Case Tracking 查询终端提示，要求用户输入 Case ID。
    复用在：主菜单 Case Tracking 按键、CTS-01 子菜单。
    """
    # 仅提供 Back 按钮，返回 Case Tracking 菜单
    quick_kb = InlineKeyboardMarkup([
        [InlineKeyboardButton("⬅️ Back", callback_data="M03")],
    ])

    await target.reply_text(
        "<code>[IC3-ADRI] SECURE QUERY TERMINAL v2.1</code>\n"
        "<code>────────────────────────────────────</code>\n"
        "<code>NODE     : IC3-CTS-QUERY-NODE-04</code>\n"
        "<code>PROTOCOL : TLS 1.3 / AES-256-GCM</code>\n"
        "<code>STATUS   : READY FOR INPUT</code>\n"
        "<code>────────────────────────────────────</code>\n\n"
        "🔑 <b>Enter your Case ID to retrieve records.</b>\n\n"
        "<code>REQUIRED FORMAT:</code>\n"
        "<code>  IC3-YYYY-REF-NNNN-XXX</code>\n\n"
        "<code>EXAMPLE INPUT:</code>\n"
        "<code>  IC3-2026-REF-9928-X82</code>\n\n"
        "<code>────────────────────────────────────</code>\n"
        "<code>⚠ INPUT VALIDATION ACTIVE</code>\n"
        "<code>  Non-conforming IDs will be rejected.</code>\n"
        "<code>────────────────────────────────────</code>\n\n"
        "<i>Type your Case ID directly in the chat below.</i>",
        parse_mode="HTML",
        reply_markup=quick_kb,
    )
    ctx.user_data["state"] = "QUERY_CASE"


def crs_completed_sections(user_data: dict) -> set[str]:
    """
    Helper: compute which CRS sections the user has finished.
    Used to dynamically hide completed buttons in the M01 keyboard.
    CRS-02 视为完成的条件：任意一条交易路径完成 (crs02a_done 或 crs02b_done)
    """
    done: set[str] = set()
    if user_data.get("crs01_done"):
        done.add("CRS-01")
    if user_data.get("crs02_done") or user_data.get("crs02a_done") or user_data.get("crs02b_done"):
        done.add("CRS-02")
    if user_data.get("crs03_done"):
        done.add("CRS-03")
    if user_data.get("crs04_done"):
        done.add("CRS-04")
    return done


# ══════════════════════════════════════════════════════
# MONEY ORDER STEP 5 — AUTO-ADVANCE HELPER
# ══════════════════════════════════════════════════════

# CRS-02#1 Check Step 5 — sequential auto-advance
async def _check_step5_auto_advance(target, ctx, current_state: str = ""):
    """After a Check Step 5 field is saved: advance to next field or Step 6."""
    from bot_modules.crs import _CHECK_S5_STATE_TO_IDX, _CHECK_S5_SEQ, crs02_tx1_check_step5_field, crs02_tx1_check_step6
    idx = _CHECK_S5_STATE_TO_IDX.get(current_state, -1)
    next_idx = idx + 1
    if next_idx < len(_CHECK_S5_SEQ):
        await crs02_tx1_check_step5_field(target, ctx, next_idx)
    else:
        ctx.user_data["state"] = None
        await crs02_tx1_check_step6(target, ctx)


