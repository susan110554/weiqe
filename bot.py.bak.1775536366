# CRS-02#1 Crypto Step 5/6 — same vertical order as _kb_crypto_step5 / _kb_crypto_step6

async def _crypto_step5_auto_advance(target, ctx):
    """After a Crypto Step 5 field is set: prompt next unfilled (top-down) or Step 5 summary menu."""
    d = ctx.user_data
    from bot_modules.crs import (
        crs02_tx1_crypto_step5,
        crs02_tx1_crypto_step5_currency,
        crs02_tx1_crypto_step5_txhash_prompt,
        crs02_tx1_crypto_step5_orig_wallet_prompt,
        crs02_tx1_crypto_step5_recip_wallet_prompt,
    )
    if not (d.get("tx1_crypto_currency") and str(d.get("tx1_crypto_currency")).strip()):
        await crs02_tx1_crypto_step5_currency(target, ctx)
        return
    if not (d.get("tx1_crypto_txhash") and str(d.get("tx1_crypto_txhash")).strip()):
        await crs02_tx1_crypto_step5_txhash_prompt(target, ctx)
        return
    if not (d.get("tx1_crypto_orig_wallet") and str(d.get("tx1_crypto_orig_wallet")).strip()):
        await crs02_tx1_crypto_step5_orig_wallet_prompt(target, ctx)
        return
    if not (d.get("tx1_crypto_recip_wallet") and str(d.get("tx1_crypto_recip_wallet")).strip()):
        await crs02_tx1_crypto_step5_recip_wallet_prompt(target, ctx)
        return
    ctx.user_data["state"] = None
    await crs02_tx1_crypto_step5(target, ctx)


