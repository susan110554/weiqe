                    "SUBMITTED": ("⚪", "SUBMITTED",
                                  "Your complaint has been successfully submitted."),
                    "PENDING REVIEW": ("🟡", "PENDING REVIEW",
                                       "Your case is awaiting assignment to an investigative team."),
                    "CASE ACCEPTED": ("🔵", "CASE ACCEPTED",
