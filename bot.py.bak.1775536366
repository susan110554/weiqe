def _liaison_idle_task_key(case_no: str) -> str:
    return (case_no or "").strip().upper()


def _liaison_idle_tasks_dict(app: Application) -> dict:
    return app.bot_data.setdefault("liaison_idle_tasks", {})


def cancel_liaison_idle_close_task(app: Application, case_no: str) -> None:
    key = _liaison_idle_task_key(case_no)
    t = _liaison_idle_tasks_dict(app).pop(key, None)
    if t is not None and not t.done():
        t.cancel()


def _liaison_idle_minutes_phrase() -> str:
    sec = max(1, int(LIAISON_IDLE_AUTO_CLOSE_SEC))
    m = max(1, (sec + 59) // 60)
    return f"{m} minute" + ("" if m == 1 else "s")


def schedule_liaison_idle_close(app: Application, case_no: str, complainant_tg_id: int) -> None:
    """用户或探员发送联络消息后调用：取消旧计时器并重新启动空闲自动关闭。"""
    cancel_liaison_idle_close_task(app, case_no)
    key = _liaison_idle_task_key(case_no)
    cn_store = (case_no or "").strip()
    uid = int(complainant_tg_id)
    idle_sec = max(1, int(LIAISON_IDLE_AUTO_CLOSE_SEC))
    mins_phrase = _liaison_idle_minutes_phrase()

    async def _idle_close():
        try:
            await asyncio.sleep(idle_sec)
        except asyncio.CancelledError:
            return
        if not await db.liaison_channel_open_for_case(cn_store):
            _liaison_idle_tasks_dict(app).pop(key, None)
            return
        await db.set_liaison(cn_store, False)
        _liaison_idle_tasks_dict(app).pop(key, None)
        try:
            await app.bot.send_message(
                uid,
                "🔒 <b>SECURE LIAISON CHANNEL — CLOSED (INACTIVITY)</b>\n"
                "━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n\n"
                f"Case: <code>{html.escape(cn_store)}</code>\n\n"
                f"No secure liaison activity was detected for <b>{html.escape(mins_phrase)}</b>.\n"
                "This channel has been <b>closed automatically</b> and is now in\n"
                "<b>read-only archive mode</b>.\n\n"
                "An authorized agent may reopen the channel if further\n"
                "communication is required.\n\n"
                f"<i>Auth Ref: <code>{AUTH_ID}</code></i>",
                parse_mode="HTML",
            )
        except Exception:
            logger.exception("liaison idle close notify failed case=%s", cn_store)

    _liaison_idle_tasks_dict(app)[key] = asyncio.create_task(_idle_close())


async def _send_case_email_with_pdf(
    to_email: str,
    case_id: str,
    pdf_bytes: bytes,
    pdf_filename: str,
    pdf_data: dict,
    attest_ts: str,
):
    """
    使用 Brevo 发送带 PDF 附件的正式案件受理邮件。
    优先走 Brevo Transactional Email API（使用 API Key），失败时回退 SMTP。
    """
    import asyncio
    import base64
    import hashlib

    # 基础字段
    fullname = pdf_data.get("fullname") or "Complainant"
    amount = str(pdf_data.get("amount") or "—")
    coin = str(pdf_data.get("coin") or "").strip()
    loss_amount = f"{amount} {coin}".strip()
    platform = pdf_data.get("platform") or "Not Provided"
    chain = pdf_data.get("chain_type") or "Not Provided"
    date_filed = attest_ts or now_str()

    # SHA-256 指纹
    pdf_sha = hashlib.sha256(pdf_bytes).hexdigest()

    subject = f"[IC3] Official Complaint Receipt Confirmation — {case_id}"

    body = (
        "INTERNET CRIME COMPLAINT CENTER\n"
        "A Division of the Federal Bureau of Investigation\n"
        "U.S. Department of Justice\n"
        "────────────────────────────────────────────────\n"
        "OFFICIAL COMPLAINT RECEIPT CONFIRMATION\n"
        "────────────────────────────────────────────────\n"
        f"Dear {fullname},\n"
        "This is an automated notification confirming receipt of your\n"
        "complaint by the Internet Crime Complaint Center (IC3).\n"
        "Please find your official case report attached to this email\n"
        "as a digitally signed PDF document. Retain this document\n"
        "for your records and future reference.\n"
        "────────────────────────────────────────────────\n"
        "COMPLAINT DETAILS\n"
        "────────────────────────────────────────────────\n"
        f"Case ID　　　　　　　{case_id}\n"
        "Status　　　　　　　⚪ SUBMITTED\n"
        f"Loss Amount　　　　{loss_amount}\n"
        f"Platform　　　　　　{platform}\n"
        f"Blockchain Network　{chain}\n"
        f"Date Filed　　　　　{date_filed}\n"
        "────────────────────────────────────────────────\n"
        "📎 ATTACHED DOCUMENT\n"
        "────────────────────────────────────────────────\n"
        f"File　　　　{pdf_filename}\n"
        "Format　　　Digitally Signed PDF\n"
        f"Integrity　　SHA-256 Verified ({pdf_sha[:16]}...)\n"
        f"Generated　　{date_filed}\n"
        "This document serves as your official case record and\n"
        "contains a complete summary of your submitted complaint.\n"
        "It has been cryptographically signed and logged to the\n"
        "federal Chain of Custody per FRE Rule 901.\n"
        "────────────────────────────────────────────────\n"
        "REQUIRED ACTIONS\n"
        "────────────────────────────────────────────────\n"
        "Save the attached PDF in a secure location.\n"
        "Retain all original communications, transaction\n"
        "records, and wallet addresses related to this incident.\n"
        "Do not destroy or alter any evidence.\n"
        "You will be notified via this email address as your\n"
        "case advances through the review process.\n"
        "Reference your Case ID in all future correspondence\n"
        "with this office.\n"
        "────────────────────────────────────────────────\n"
        "⚠️ FRAUD WARNING\n"
        "────────────────────────────────────────────────\n"
        "IC3 and the FBI do NOT charge any fees for complaint\n"
        "submission, case processing, asset recovery, or legal\n"
        "documentation. Any payment request made in the name\n"
        "of IC3 or the FBI is fraudulent.\n"
        "If you receive such a request, report it immediately.\n"
        "────────────────────────────────────────────────\n"
        "LEGAL NOTICE\n"
        "────────────────────────────────────────────────\n"
        "All information submitted is subject to verification\n"
        "under 18 U.S.C. § 1001. Knowingly providing false\n"
        "statements to federal investigators is a criminal offense.\n"
        "This communication is intended solely for the registered\n"
        "complainant. Unauthorized disclosure is prohibited.\n"
        "────────────────────────────────────────────────\n"
        "IC3 AUTOMATED SYSTEM MESSAGE\n"
        "INTERNET CRIME COMPLAINT CENTER\n"
        "IC3-SYSTEM · NODE-09 · VERIFIED\n"
        f"{FEDERAL_INDEX_LINE}\n"
        "🆔 SESSION HASH: [ 55b6...9f4a ]\n"
        "This is an automated message. Do not reply to this email.\n"
        "────────────────────────────────────────────────\n"
    )

    # ── 1) Brevo Transactional Email API (recommended) ─────────────
    # 优先使用 API；仅在未配置 API key 时才尝试 SMTP，避免把真实 API 错误掩盖为 SMTP 认证失败。
    if BREVO_API_KEY:
        try:
            import aiohttp
            payload = {
                "sender": {"name": SMTP_FROM_NAME, "email": SMTP_FROM_EMAIL},
                "to": [{"email": to_email}],
                "subject": subject,
                "textContent": body,
                "attachment": [
                    {
                        "content": base64.b64encode(pdf_bytes).decode("ascii"),
                        "name": pdf_filename,
                    }
                ],
            }
            headers = {
                "api-key": BREVO_API_KEY,
                "content-type": "application/json",
                "accept": "application/json",
            }
            async with aiohttp.ClientSession(timeout=aiohttp.ClientTimeout(total=20)) as session:
                async with session.post("https://api.brevo.com/v3/smtp/email", json=payload, headers=headers) as resp:
                    if 200 <= resp.status < 300:
                        return
                    err_txt = await resp.text()
                    msg = f"Brevo API send failed: status={resp.status} body={(err_txt or '')[:400]}"
                    logger.error(msg)
                    raise RuntimeError(msg)
        except Exception as e:
            logger.error("Brevo API send exception: %r", e)
            raise

    # ── 2) Fallback: SMTP relay (only when SMTP creds configured) ───────────
    if not SMTP_USER or not SMTP_PASSWORD:
        raise RuntimeError("Email sending is not configured: missing BREVO_API_KEY and SMTP credentials.")

    msg = EmailMessage()
    msg["Subject"] = subject
    msg["From"] = f"{SMTP_FROM_NAME} <{SMTP_FROM_EMAIL}>"
    msg["To"] = to_email
    msg.set_content(body)
    msg.add_attachment(pdf_bytes, maintype="application", subtype="pdf", filename=pdf_filename)

    def _send_sync():
        with smtplib.SMTP(SMTP_HOST, SMTP_PORT, timeout=15) as server:
            server.starttls()
            server.login(SMTP_USER, SMTP_PASSWORD)
            server.send_message(msg)

    await asyncio.to_thread(_send_sync)


async def _send_plain_transactional_email(to_email: str, subject: str, body: str) -> None:
    """无附件的纯文本事务邮件（Brevo API 优先，其次 SMTP）。"""
    import asyncio

    if BREVO_API_KEY:
        try:
            import aiohttp
            payload = {
                "sender": {"name": SMTP_FROM_NAME, "email": SMTP_FROM_EMAIL},
                "to": [{"email": to_email}],
                "subject": subject,
                "textContent": body,
            }
            headers = {
                "api-key": BREVO_API_KEY,
                "content-type": "application/json",
                "accept": "application/json",
            }
            async with aiohttp.ClientSession(timeout=aiohttp.ClientTimeout(total=20)) as session:
                async with session.post("https://api.brevo.com/v3/smtp/email", json=payload, headers=headers) as resp:
                    if 200 <= resp.status < 300:
                        return
                    err_txt = await resp.text()
                    raise RuntimeError(
                        f"Brevo email failed: status={resp.status} body={(err_txt or '')[:300]}"
                    )
        except Exception:
            logger.exception("Plain transactional email via Brevo failed")
            raise

    if not SMTP_USER or not SMTP_PASSWORD:
        raise RuntimeError("Email unavailable: missing BREVO_API_KEY and SMTP credentials.")

    msg = EmailMessage()
    msg["Subject"] = subject
    msg["From"] = f"{SMTP_FROM_NAME} <{SMTP_FROM_EMAIL}>"
    msg["To"] = to_email
    msg.set_content(body)

    def _send_sync():
        with smtplib.SMTP(SMTP_HOST, SMTP_PORT, timeout=15) as server:
            server.starttls()
            server.login(SMTP_USER, SMTP_PASSWORD)
            server.send_message(msg)

    await asyncio.to_thread(_send_sync)


async def _send_recovery_code_email(to_email: str, code: str):
    """Send account-recovery OTP email."""
    subject = "[IC3] PIN Recovery Verification Code"
    body = (
        "IC3 ACCOUNT RECOVERY\n"
        "────────────────────────────────────────────────\n"
        "Your 6-digit verification code is:\n\n"
        f"{code}\n\n"
        f"Expires in {RECOVERY_CODE_EXPIRY_MIN} minutes.\n\n"
        "If you did not request this code, please ignore this email.\n"
        "IC3 Automated Security Notice."
    )
    await _send_plain_transactional_email(to_email, subject, body)
