        await q.answer()
        return
    if data == "CRS03_C_BACK":
        from bot_modules.crs import crs03_main_menu
        await crs03_main_menu(q.message, ctx)
        await q.answer()
        return
    if data == "CRS03_FIELD_SKIP":
        _c03_skip_map = {
            # Contact Info fields → advance to next field
            "CRS03_STATE_C_NAME":    ("crs03_subject_name",    "contact"),
            "CRS03_STATE_C_PHONE":   ("crs03_subject_phone",   "contact"),
            "CRS03_STATE_C_EMAIL":   ("crs03_subject_email",   "contact"),
            "CRS03_STATE_C_ADDRESS": ("crs03_subject_address", "contact"),
            "CRS03_STATE_C_CITY":    ("crs03_subject_city",    "contact"),
            "CRS03_STATE_C_COUNTRY": ("crs03_subject_country", "contact"),
            # Single-field prompts → return to main menu
            "CRS03_STATE_PLATFORM":  ("platform",   "main"),
            "CRS03_STATE_PROFILE":   ("profile_url","main"),
        }
        cur = ctx.user_data.get("state", "")
        entry = _c03_skip_map.get(cur)
        if entry:
            data_key, dest = entry
            ctx.user_data[data_key] = "➖Not Provided"
            await q.message.reply_text("➖Not Provided")
            if dest == "contact":
                from bot_modules.crs import crs03_contact_advance as _adv
                await _adv(q.message, ctx, cur)
            else:
                ctx.user_data["state"] = None
                from bot_modules.crs import crs03_main_menu as _mm
                await _mm(q.message, ctx)
        else:
            ctx.user_data["state"] = None
            from bot_modules.crs import crs03_main_menu as _mm
            await _mm(q.message, ctx)
        await q.answer()
        return
    if data == "CRS03_FIELD_BACK":
