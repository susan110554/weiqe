        await crs02_tx1_crypto_step5(q.message, ctx)
        await q.answer()
        return
    if data and data.startswith("CRYPTO_S5_CUR_") and data != "CRYPTO_S5_CUR_OTHER":
        cur_map = {
            "CRYPTO_S5_CUR_BTC": "Bitcoin (BTC)",
            "CRYPTO_S5_CUR_ETH": "Ethereum (ETH)",
            "CRYPTO_S5_CUR_USDT": "Tether (USDT)",
            "CRYPTO_S5_CUR_USDC": "USDC",
            "CRYPTO_S5_CUR_BNB": "BNB",
            "CRYPTO_S5_CUR_XRP": "XRP",
        }
        ctx.user_data["tx1_crypto_currency"] = cur_map.get(data, data)
        lbl = ctx.user_data["tx1_crypto_currency"]
        await q.message.reply_text(f"✅ Cryptocurrency Type recorded.\n\n{lbl}", parse_mode="HTML")
        await _crypto_step5_auto_advance(q.message, ctx)
        await q.answer()
        return
    if data == "CRYPTO_S5_CUR_OTHER":
        ctx.user_data["state"] = "CRS02_TX1_CRYPTO_CURRENCY_OTHER"
        await q.message.reply_text(
            "✏️ <b>Type of Cryptocurrency (Other)</b>\n\n"
            "Please reply with the cryptocurrency name (e.g. Solana, Dogecoin).",
            parse_mode="HTML",
        )
        await q.answer()
        return
    # Crypto Step 6: ATM/Kiosk — sequential field prompts
    if data == "CRYPTO_S6_SKIP":
        # Mark current field as skipped, advance to next
        cur_state = ctx.user_data.get("state", "")
        from bot_modules.crs import _CRYPTO_ATM_STATE_TO_IDX, _CRYPTO_ATM_SEQ, crs02_tx1_crypto_step6_field, crs02_tx1_crypto_step7
        idx = _CRYPTO_ATM_STATE_TO_IDX.get(cur_state, -1)
        if idx >= 0:
            data_key = _CRYPTO_ATM_SEQ[idx][0]
            ctx.user_data[data_key] = "Not Provided"
            await q.message.reply_text("➖Not Provided")
        next_idx = idx + 1
        if next_idx < len(_CRYPTO_ATM_SEQ):
            await crs02_tx1_crypto_step6_field(q.message, ctx, next_idx)
        else:
            ctx.user_data["state"] = None
            await crs02_tx1_crypto_step7(q.message, ctx)
        await q.answer()
        return
    if data == "CRYPTO_S6_FIELD_BACK":
        # Go back to previous field or Step 5
        cur_state = ctx.user_data.get("state", "")
        from bot_modules.crs import _CRYPTO_ATM_STATE_TO_IDX, crs02_tx1_crypto_step6_field, crs02_tx1_crypto_step5
        idx = _CRYPTO_ATM_STATE_TO_IDX.get(cur_state, 0)
        if idx > 0:
            await crs02_tx1_crypto_step6_field(q.message, ctx, idx - 1)
        else:
            ctx.user_data["state"] = None
            await crs02_tx1_crypto_step5(q.message, ctx)
        await q.answer()
        return
    if data == "CRYPTO_S6_SAVE":
        from bot_modules.crs import crs02_tx1_crypto_step7
        await crs02_tx1_crypto_step7(q.message, ctx)
        await q.answer()
        return
    if data == "CRYPTO_S6_BACK":
        from bot_modules.crs import crs02_tx1_crypto_step5
        await crs02_tx1_crypto_step5(q.message, ctx)
        await q.answer()
        return
    # Crypto Step 7: Summary — Edit / Save
    if data == "CRYPTO_S7_EDIT":
        from bot_modules.crs import crs02_tx1_crypto_step5
        await crs02_tx1_crypto_step5(q.message, ctx)
        await q.answer()
        return
    if data == "CRYPTO_S7_SAVE":
        d = ctx.user_data
        d["crs02_done"] = True
        d["amount"] = d.get("tx1_crypto_amount") or d.get("amount")
        d["coin"] = "USD"
        if d.get("tx1_crypto_recip_wallet"):
            d["wallet_addr"] = d["wallet"] = d["tx1_crypto_recip_wallet"]
        if d.get("tx1_crypto_txhash"):
            d["txid"] = d["tx1_crypto_txhash"]
        if d.get("tx1_crypto_orig_wallet"):
            d["victim_wallet"] = d["tx1_crypto_orig_wallet"]
        ctx.user_data["state"] = None
        await q.answer("Submitted.")
        n = ctx.user_data.get("current_tx_num", 1)
        ctx.user_data.setdefault("tx_done", {})[n] = True
        _tx_snapshot_bot(ctx)
        await q.message.reply_text(f"✅ <b>Transaction #{n} saved.</b>", parse_mode="HTML")
        from bot_modules.crs import crs02_financial_transactions_menu
        await crs02_financial_transactions_menu(q.message, ctx)
        return
    if data == "CRS02_FIN_ADD":
        tx_count = ctx.user_data.get("tx_count", 1)
        if tx_count >= 10:
            await q.answer("Maximum 10 transactions reached.", show_alert=True)
            return
        _tx_snapshot_bot(ctx)
        new_n = tx_count + 1
        ctx.user_data["tx_count"] = new_n
        ctx.user_data["current_tx_num"] = new_n
        # Clear tx1_* keys for new transaction
        for k in [k for k in list(ctx.user_data.keys()) if k.startswith("tx1_")]:
            del ctx.user_data[k]
        ctx.user_data.pop("wire_s5_expanded", None)
        ctx.user_data.pop("other_s6_expanded", None)
        from bot_modules.crs import crs02_financial_tx1_type
        await crs02_financial_tx1_type(q.message, ctx)
        await q.answer()
        return
    if data == "CRS02_FIN_BACK":
        from bot_modules.crs import crs02_financial_transactions_menu
        await crs02_financial_transactions_menu(q.message, ctx)
        await q.answer()
        return
    if data == "CRS02_FIN_CANCEL":
        ctx.user_data["state"] = None
        await q.answer("Cancelled.")
        await q.message.reply_text(
            "Financial transaction review cancelled. You may continue with other sections.",
            parse_mode="HTML",
            reply_markup=kb_m01_for_user(crs_completed_sections(ctx.user_data)),
        )
        return

    if data == "CRS-03":
