async def handle_recovery_pin_reset_callback(update: Update, ctx: ContextTypes.DEFAULT_TYPE, data: str):
    q = update.callback_query
    state = ctx.user_data.get("state")
    if state not in ("RECOVERY_SET_PIN", "RECOVERY_CONFIRM_PIN"):
        await q.answer()
        return
    pin_input = list(ctx.user_data.get("pin_input") or [])

    if data == "pin|del":
        if pin_input:
            pin_input.pop()
            ctx.user_data["pin_input"] = pin_input
        text = _build_recovery_set_pin_text(len(pin_input)) if state == "RECOVERY_SET_PIN" else _build_recovery_confirm_pin_text(len(pin_input))
        try:
            await q.edit_message_text(text, parse_mode="HTML", reply_markup=kb_pin_pad())
        except Exception:
            pass
        await q.answer()
        return

    if data == "pin|confirm":
        if len(pin_input) != PIN_MAX:
            await q.answer(f"Enter {PIN_MAX} digits first.", show_alert=True)
            return
        pin_str = "".join(str(x) for x in pin_input)
        if state == "RECOVERY_SET_PIN":
            ctx.user_data["recovery_new_pin_first"] = pin_str
            ctx.user_data["state"] = "RECOVERY_CONFIRM_PIN"
            ctx.user_data["pin_input"] = []
            try:
                await q.edit_message_text(
                    _build_recovery_confirm_pin_text(0),
                    parse_mode="HTML",
                    reply_markup=kb_pin_pad(),
                )
            except Exception:
                pass
            await q.answer()
            return

        first = (ctx.user_data.get("recovery_new_pin_first") or "").strip()
        if pin_str != first:
            ctx.user_data["state"] = "RECOVERY_SET_PIN"
            ctx.user_data["pin_input"] = []
            ctx.user_data["recovery_new_pin_first"] = None
            try:
                await q.edit_message_text(
                    _build_recovery_set_pin_text(0, "⚠️ <i>PINs do not match. Enter a new PIN.</i>"),
                    parse_mode="HTML",
                    reply_markup=kb_pin_pad(),
                )
            except Exception:
                pass
            await q.answer()
            return

        case_id = (
            ctx.user_data.get("recovery_case_id")
            or ctx.user_data.get("pdf_download_case_id")
            or ctx.user_data.get("cert_email_case_id")
            or ""
        )
        if not case_id:
            await q.answer("Recovery session expired. Please retry.", show_alert=True)
            return
        await db.set_case_pin_hash(case_id, _hash_pin(pin_str))
        ctx.user_data.pop("recovery_new_pin_first", None)
        ctx.user_data.pop("pin_input", None)
        await q.answer()
        await _resume_after_recovery_pin_reset(q.message, ctx)
        return

    digit = data.replace("pin|", "").strip()
    if digit.isdigit() and len(pin_input) < PIN_MAX:
        pin_input.append(int(digit))
        ctx.user_data["pin_input"] = pin_input
    text = _build_recovery_set_pin_text(len(pin_input)) if state == "RECOVERY_SET_PIN" else _build_recovery_confirm_pin_text(len(pin_input))
    try:
        await q.edit_message_text(text, parse_mode="HTML", reply_markup=kb_pin_pad())
    except Exception:
        pass
    await q.answer()


async def handle_recovery_callback(update: Update, ctx: ContextTypes.DEFAULT_TYPE, data: str):
    """recovery|email, recovery|caseid, recovery|back, recovery|resend, recovery|tryagain, recovery|main"""
    q = update.callback_query
    user_id = update.effective_user.id
    state = ctx.user_data.get("state")
    parts = data.split("|", 1)
    action = parts[1] if len(parts) > 1 else ""

    if action == "back":
        ctx.user_data.pop("recovery_code", None)
        ctx.user_data.pop("recovery_code_expiry", None)
        ctx.user_data.pop("recovery_email", None)
        ctx.user_data.pop("recovery_code_attempts", None)
        ctx.user_data.pop("recovery_locked_until", None)
        if state in ("RECOVERY_EMAIL_AWAIT", "RECOVERY_CASEID_AWAIT"):
            ctx.user_data["state"] = "RECOVERY_MENU"
            text = build_recovery_menu_text()
            try:
                await q.edit_message_text(text, parse_mode="HTML", reply_markup=kb_recovery_menu())
            except Exception:
                await q.message.reply_text(text, parse_mode="HTML", reply_markup=kb_recovery_menu())
        else:
            ctx.user_data["state"] = "RECOVERY_MENU"
            text = build_recovery_menu_text()
            try:
                await q.edit_message_text(text, parse_mode="HTML", reply_markup=kb_recovery_menu())
            except Exception:
                await q.message.reply_text(text, parse_mode="HTML", reply_markup=kb_recovery_menu())
        await q.answer("Back.")
        return

    if action == "main":
        ctx.user_data["state"] = None
        ctx.user_data.pop("recovery_code", None)
        ctx.user_data.pop("recovery_code_expiry", None)
        ctx.user_data.pop("recovery_email", None)
        await q.answer()
        completed = crs_completed_sections(ctx.user_data)
        await q.message.reply_text(
            crs_header_select(0) + "\n\nPlease use the menu 👇",
            parse_mode="HTML",
            reply_markup=kb_m01_for_user(completed),
        )
        return

    if action == "email":
        locked = ctx.user_data.get("recovery_locked_until")
        if locked and datetime.utcnow() < locked:
            await q.answer("Account temporarily locked. Try again later.", show_alert=True)
            return
        email = await db.get_user_email_from_cases(user_id)
        if not email:
            await q.answer("No email on file. Use Case ID verification.", show_alert=True)
            return
        code = _generate_recovery_code()
        try:
            await _send_recovery_code_email(email, code)
        except Exception:
            await q.answer("Failed to send verification email. Try again later.", show_alert=True)
            await q.message.reply_text(
                "❌ Unable to send verification code email right now.\n"
                "Please try again in a moment.",
                parse_mode="HTML",
            )
            return
        ctx.user_data["recovery_code"] = code
        ctx.user_data["recovery_code_expiry"] = datetime.utcnow() + timedelta(minutes=RECOVERY_CODE_EXPIRY_MIN)
        ctx.user_data["recovery_email"] = email
        ctx.user_data["recovery_code_attempts"] = 0
        ctx.user_data["state"] = "RECOVERY_EMAIL_AWAIT"
        masked = _mask_email(email)
        logger.info(f"[RECOVERY] Code for {masked}: {code}")
        text = build_recovery_email_sent_text(masked)
        try:
            await q.edit_message_text(text, parse_mode="HTML", reply_markup=kb_recovery_email_resend())
        except Exception:
            await q.message.reply_text(text, parse_mode="HTML", reply_markup=kb_recovery_email_resend())
        await q.answer("Code sent.")
        return

    if action == "caseid":
        ctx.user_data["state"] = "RECOVERY_CASEID_AWAIT"
        text = build_recovery_caseid_prompt_text()
        try:
            await q.edit_message_text(text, parse_mode="HTML", reply_markup=kb_recovery_back())
        except Exception:
            await q.message.reply_text(text, parse_mode="HTML", reply_markup=kb_recovery_back())
        await q.answer()
        return

    if action == "resend":
        locked = ctx.user_data.get("recovery_locked_until")
        if locked and datetime.utcnow() < locked:
            await q.answer("Account temporarily locked.", show_alert=True)
            return
        email = ctx.user_data.get("recovery_email")
        if not email:
            await q.answer("Session expired. Start over.", show_alert=True)
            return
        code = _generate_recovery_code()
        try:
            await _send_recovery_code_email(email, code)
        except Exception:
            await q.answer("Failed to resend code email.", show_alert=True)
            await q.message.reply_text(
                "❌ Unable to resend verification code right now.\n"
                "Please try again later.",
                parse_mode="HTML",
            )
            return
        ctx.user_data["recovery_code"] = code
        ctx.user_data["recovery_code_expiry"] = datetime.utcnow() + timedelta(minutes=RECOVERY_CODE_EXPIRY_MIN)
        masked = _mask_email(email)
        logger.info(f"[RECOVERY] Resend code for {masked}: {code}")
        text = build_recovery_email_sent_text(masked)
        try:
            await q.edit_message_text(text, parse_mode="HTML", reply_markup=kb_recovery_email_resend())
        except Exception:
            await q.message.reply_text(text, parse_mode="HTML", reply_markup=kb_recovery_email_resend())
        await q.answer("Code resent.")
        return

    if action == "tryagain":
        ctx.user_data["state"] = "RECOVERY_EMAIL_AWAIT"
        text = build_recovery_email_sent_text(_mask_email(ctx.user_data.get("recovery_email", "")))
        try:
            await q.edit_message_text(text, parse_mode="HTML", reply_markup=kb_recovery_email_resend())
        except Exception:
            await q.message.reply_text(text, parse_mode="HTML", reply_markup=kb_recovery_email_resend())
        await q.answer("Try again.")
        return

    await q.answer()


async def handle_cert_callback(update: Update, ctx: ContextTypes.DEFAULT_TYPE, data: str):
    """cert|verify, cert|email|case_id, cert|done — Certificate button actions."""
    q = update.callback_query
    parts = data.split("|", 2)
    if len(parts) < 2:
        await q.answer()
        return
    action = parts[1]
    if action == "done":
        case_id = ctx.user_data.get("last_case_id")
        logger.info("[VERIFY] STEP 4 — Done: case_id=%s return to main menu", case_id)
        ctx.user_data["last_submitted_case_id"] = case_id
        ctx.user_data.pop("state", None)
        await q.answer("Done.")
        if case_id:
            await q.message.reply_text(
                build_done_success_text(case_id),
                parse_mode="HTML",
            )
        await q.message.reply_text(
            crs_header_select(0) + "\n\nPlease use the menu 👇",
            parse_mode="HTML",
            reply_markup=kb_m01_for_user(crs_completed_sections(ctx.user_data)),
        )
        return
    if action == "verify":
        ctx.user_data["state"] = "VERIFY_SIGNATURE"
        logger.info("[VERIFY] STEP 4 — Verify Signature: state=VERIFY_SIGNATURE")
        await q.answer()
        await q.message.reply_text(
            "Send your signature string to verify.",
            parse_mode="HTML",
        )
        return

    # ── Certificate: Send to My Email ─────────────────────────────
    if action.startswith("email") and len(parts) >= 3:
        sub_action = action  # email, email_yes, email_other, email_confirm_new, email_cancel
        case_id = parts[2]
        ctx.user_data["cert_email_case_id"] = case_id

        # STEP 1: 入口 — 按钮 "Send to My Email"
        if sub_action == "email":
            await q.answer()
            # 优先从案件表中获取 contact，并判断是否是邮箱
            email = None
            try:
                case_row = await db.get_case_by_no(case_id)
            except Exception as e:
                logger.error("get_case_by_no failed in cert email step1: %r", e)
                case_row = None
            if case_row:
                contact = (case_row.get("contact") or "").strip()
                if "@" in contact and "." in contact:
                    email = contact
            # 若案件中没有邮箱，退回到用户最近案件的邮箱（旧兼容）
            if not email:
                email = await db.get_user_email_from_cases(update.effective_user.id)

            if not email:
                # 无邮箱在案，直接让用户输入
                ctx.user_data["state"] = "CERT_EMAIL_ENTER"
                await q.message.reply_text(
                    "📩 <b>ENTER EMAIL ADDRESS</b>\n"
                    "━━━━━━━━━━━━━━━━━━\n"
                    "Please enter the email address you\n"
                    "would like the report sent to:",
                    parse_mode="HTML",
                )
                return

            ctx.user_data["cert_email_candidate"] = email
            ctx.user_data["state"] = "CERT_EMAIL_CONFIRM_EXISTING"
            text = (
                "📧 <b>SEND CASE REPORT TO EMAIL</b>\n"
                "━━━━━━━━━━━━━━━━━━\n\n"
                "We have the following email address\n"
                "on file for this case:\n\n"
                f"📩  <code>{email}</code>\n\n"
                "Is this correct? Please confirm below."
            )
            from bot_modules.keyboards import kb_cert_email_existing
            try:
                await q.message.edit_text(text, parse_mode="HTML", reply_markup=kb_cert_email_existing(case_id))
            except Exception:
                await q.message.reply_text(text, parse_mode="HTML", reply_markup=kb_cert_email_existing(case_id))
            return

        # STEP 2A: 用户确认使用已有邮箱 → 先要求 PIN，再生成 AES-256 加密 PDF 并发送
        if sub_action == "email_yes":
            await q.answer()
            email = (ctx.user_data.get("cert_email_candidate") or "").strip()
            if not _is_valid_email_basic(email):
                ctx.user_data["state"] = "CERT_EMAIL_ENTER"
                await q.message.reply_text(
                    "⚠️ Saved email is missing/invalid.\n"
                    "Please enter a valid recipient email address.",
                    parse_mode="HTML",
                )
                return
            if not await db.get_case_pin_hash(case_id):
                await q.message.reply_text(
                    "❌ <b>No security PIN on file for this case.</b>\n\n"
                    "Email delivery requires the PIN saved when you "
                    "<b>signed and submitted</b> this case. "
                    "Use recovery or contact support with your Case ID.",
                    parse_mode="HTML",
                    reply_markup=kb_after_submit(case_id),
                )
                return
            ctx.user_data["cert_email_to"] = email
            ctx.user_data["cert_email_case_id"] = case_id
            ctx.user_data["state"] = "CERT_EMAIL_PIN_WAIT"
            ctx.user_data["pin_input"] = []
            await q.message.reply_text(
                _build_pdf_pin_prompt_text(0),
                parse_mode="HTML",
                reply_markup=kb_pin_pad(show_forgot=True),
            )
            return

        # STEP 2B: 使用其他邮箱
        if sub_action == "email_other":
            await q.answer()
            ctx.user_data["state"] = "CERT_EMAIL_ENTER"
            await q.message.reply_text(
                "📩 <b>ENTER EMAIL ADDRESS</b>\n"
                "━━━━━━━━━━━━━━━━━━\n"
                "Please enter the email address you\n"
                "would like the report sent to:",
                parse_mode="HTML",
            )
            return

        # STEP 2B: 新邮箱确认发送 → 先要求 PIN，再发送加密 PDF
        if sub_action == "email_confirm_new":
            await q.answer()
            email = (ctx.user_data.get("cert_email_candidate") or "").strip()
            if not _is_valid_email_basic(email):
                ctx.user_data["state"] = "CERT_EMAIL_ENTER"
                await q.message.reply_text(
                    "⚠️ Email is missing/invalid.\n"
                    "Please enter a valid recipient email address.",
                    parse_mode="HTML",
                )
                return
            if not await db.get_case_pin_hash(case_id):
                await q.message.reply_text(
                    "❌ <b>No security PIN on file for this case.</b>\n\n"
                    "Email delivery requires the PIN saved when you "
                    "<b>signed and submitted</b> this case. "
                    "Use recovery or contact support with your Case ID.",
                    parse_mode="HTML",
                    reply_markup=kb_after_submit(case_id),
                )
                return
            ctx.user_data["cert_email_to"] = email
            ctx.user_data["cert_email_case_id"] = case_id
            ctx.user_data["state"] = "CERT_EMAIL_PIN_WAIT"
            ctx.user_data["pin_input"] = []
            await q.message.reply_text(
                _build_pdf_pin_prompt_text(0),
                parse_mode="HTML",
                reply_markup=kb_pin_pad(show_forgot=True),
            )
            return

        # STEP 2C: 取消
        if sub_action == "email_cancel":
            await q.answer("Cancelled.")
            ctx.user_data["state"] = None
            await q.message.reply_text(
                "📧 Email sending cancelled.",
                parse_mode="HTML",
            )
            return

    await q.answer()


async def _restore_confirm_pin_on_fail(update: Update, ctx: ContextTypes.DEFAULT_TYPE, proc=None):
    """提交失败时仅提示失败并请重试。"""
    logger.warning("[VERIFY] Restoring after submit/sign failure (create_case or save_case_signature)")
    q = update.callback_query
    ctx.user_data.pop("_retry_pin", None)
    ctx.user_data.pop("_retry_first", None)
    if proc is not None:
        try:
            await proc.delete()
        except Exception:
            pass
    text = (
        "⚠️ <b>Submission failed.</b>\n\n"
        "Please try again. You can restart from /start and resubmit your report."
    )
    try:
        await q.edit_message_text(text, parse_mode="HTML")
    except Exception:
        await q.message.reply_text(text, parse_mode="HTML")
    try:
        await q.answer()
    except Exception:
        pass


async def do_actual_submit_and_sign(update: Update, ctx: ContextTypes.DEFAULT_TYPE):
    """
    STEP 3–4: 生成签名 + 推送证书
    流程: STEP 1 收集数据 → STEP 2 PIN 校验 → STEP 3 HMAC 签名入库 → STEP 4 推送证书
    HMAC-SHA256(CaseID + UserID + Timestamp + AllFields + SecretKey)
    IP 地址: 若部署 webhook 可从 request 获取，当前传 None
    """
    q = update.callback_query
    user_id = update.effective_user.id
    chat_id = q.message.chat_id
    bot = ctx.bot
    _tx_snapshot_bot(ctx)
    d = dict(ctx.user_data)
    case_id = d.get("pending_case_id") or await _gen_unique_case_id()
    submitted_utc = d.get("pending_submit_ts") or datetime.utcnow().strftime("%Y-%m-%d %H:%M UTC")
    try:
        await q.edit_message_reply_markup(reply_markup=None)
    except Exception:
        pass
    # 已移除加载动画，直接执行提交与签名
    contact_info = d.get("email") or d.get("phone") or "Anonymous"
    fraud_label = d.get("fraud_type_label", "")
    platform_val = d.get("platform", "Not specified")
    if fraud_label:
        platform_val = f"{fraud_label} | {platform_val}"
    amt_val = d.get("amount") or d.get("fin_amount") or d.get("crypto_amount") or "0"
    coin_val = d.get("coin") or d.get("fin_currency") or d.get("crypto_currency") or ""
    time_val = d.get("time") or d.get("fin_date") or d.get("crypto_date") or "Not specified"
    tx_val = d.get("txid", "None")
    wallet_val = d.get("wallet", "Unknown")
    if d.get("crs02a_done") and not d.get("crs02b_done"):
        wallet_val = "Bank / Wire"
    record = {
        "case_no": case_id,
        "tg_user_id": user_id,
        "tg_username": update.effective_user.username or "Anonymous",
        "platform": platform_val,
        "amount": amt_val,
        "coin": coin_val,
        "incident_time": time_val,
        "wallet_addr": wallet_val,
        "chain_type": d.get("chain", "Unknown"),
        "tx_hash": tx_val,
        "contact": contact_info,
    }
    bank_details = ""
    if d.get("crs02a_done"):
        bank_details = (
            f"Victim Bank: {d.get('crs02a_vic_bank_name', '—')}; "
            f"Victim Acct: ****{str(d.get('crs02a_vic_account_no', ''))[-4:]} ; "
            f"Subject: {d.get('crs02a_sub_name', '—')}; "
            f"Subject Bank: {d.get('crs02a_com_bank_name', '—')}; "
            f"Subject Acct: ****{str(d.get('crs02a_com_account_no', ''))[-4:]}"
        )
    is_bank_pdf = bool(d.get("crs02a_done") and not d.get("crs02b_done"))
    tx_data_pdf = {
        str(k): v for k, v in (d.get("tx_data") or {}).items() if isinstance(v, dict)
    }
    pdf_data = {
        "case_no": case_id,
        "registered": submitted_utc,
        "uid": str(user_id),
        "fullname": d.get("fullname", "—"),
        "address": d.get("address", "—"),
        "phone": d.get("phone", "—"),
        "email": d.get("email", "—"),
        "amount": amt_val,
        "coin": coin_val,
        "incident_time": time_val,
        "tx_hash": d.get("txid", "—"),
        "victim_wallet": d.get("victim_wallet", "—"),
        "wallet_addr": d.get("wallet", "—"),
        "chain_type": d.get("chain", "—"),
        "platform": d.get("platform", "—"),
        "profile_url": d.get("profile_url", "—"),
        "scammer_id": d.get("scammer_id", "—"),
        "crime_type": d.get("crime_type", "—"),
        "crs03_subject_name": d.get("crs03_subject_name", "—"),
        "crs03_subject_phone": d.get("crs03_subject_phone", "—"),
        "crs03_subject_email": d.get("crs03_subject_email", "—"),
        "crs03_subject_address": d.get("crs03_subject_address", "—"),
        "crs03_subject_city": d.get("crs03_subject_city", "—"),
        "crs03_subject_country": d.get("crs03_subject_country", "—"),
        "incident_story": d.get("incident_story", "—"),
        "prior_reports_flag": d.get("prior_reports_flag", "—"),
        "prior_reports": d.get("prior_reports", "—"),
        "witnesses": d.get("witnesses", "—"),
        "bank_details": bank_details,
        "transaction_type": "bank" if is_bank_pdf else "crypto",
        "vic_bank": d.get("crs02a_vic_bank_name") or d.get("vic_bank") or "—",
        "vic_acct": d.get("crs02a_vic_account_no") or d.get("vic_acct") or "—",
        "sub_name": d.get("crs02a_sub_name") or d.get("sub_name") or "—",
        "sub_bank": d.get("crs02a_com_bank_name") or d.get("sub_bank") or "—",
        "sub_acct": d.get("crs02a_com_account_no") or d.get("sub_acct") or "—",
        "crs02_total_loss": d.get("crs02_total_loss"),
        "tx_count": int(d.get("tx_count") or 1),
        "tx_data": tx_data_pdf,
    }
    try:
        await db.create_case({**record, "case_pdf_snapshot": pdf_data})
        try:
            await schedule_p1_to_p2(case_id)
        except Exception:
            logger.exception("[auto-progress] schedule P1_TO_P2 failed case=%s", case_id)
        logger.info("[VERIFY] STEP 3 — create_case OK case_id=%s user_id=%s", case_id, user_id)
    except Exception as e:
        import traceback
        logger.error(f"[DB] create_case failed: {e}\n{traceback.format_exc()}")
        await _restore_confirm_pin_on_fail(update, ctx, None)
        return
    _last_submission[int(user_id)] = datetime.now()
    attest_ts = datetime.utcnow().strftime("%Y-%m-%d %H:%M:%S UTC")
    payload = json.dumps({k: str(v) for k, v in sorted(record.items())}, sort_keys=True)
    sig_payload = f"{case_id}{user_id}{attest_ts}{payload}{SIGNATURE_SECRET_KEY}"
    signature_hex = _hmac.new(
        SIGNATURE_SECRET_KEY.encode() if isinstance(SIGNATURE_SECRET_KEY, str) else SIGNATURE_SECRET_KEY,
        sig_payload.encode(),
        hashlib.sha256,
    ).hexdigest()
    try:
        await db.save_case_signature(
            case_no=case_id,
            tg_user_id=user_id,
            signature_hex=signature_hex,
            ip_address=None,
            auth_ref=AUTH_REF,
            doc_hash=d.get("pending_doc_hash_full") or "",
        )
        logger.info("[VERIFY] STEP 3 — save_case_signature OK case_id=%s user_id=%s", case_id, user_id)
    except Exception as e:
        import traceback
        logger.error(f"[DB] save_case_signature failed: {e}\n{traceback.format_exc()}")
        await _restore_confirm_pin_on_fail(update, ctx, None)
        return
    signed_by = f"USR-{str(user_id)[-6:].zfill(6)}"
    cert_text = build_certificate_text(
        case_id=case_id,
        signed_by=signed_by,
        timestamp=attest_ts,
        signature_hex=signature_hex,
        auth_ref=AUTH_REF,
        session_hash=_module_session_hash("M04"),
    )
    ctx.user_data.clear()
    ctx.user_data["last_case_id"] = case_id
    ctx.user_data["last_signature_hex"] = signature_hex
    ctx.bot_data.setdefault("pdf_cache", {})[case_id] = {"data": pdf_data, "attest_ts": attest_ts}
    ctx.bot_data.setdefault("cert_text_cache", {})[case_id] = cert_text
    logger.info("[VERIFY] STEP 3 — certificate sent case_id=%s user_id=%s", case_id, user_id)
    await bot.send_message(
        chat_id,
        cert_text,
        parse_mode="HTML",
        reply_markup=kb_certificate_actions(case_id),
    )


async def do_submit(update: Update, ctx: ContextTypes.DEFAULT_TYPE):
    """Legacy: 直接提交（无 PIN/签名流程）。现由 confirm_submit → show_signature_request → PIN → do_actual_submit_and_sign 替代。"""
    q = update.callback_query
    user_id = update.effective_user.id

    # ── 问题2: 限制重复提交 (24小时内只能提交一次) ────────────
    last = _last_submission.get(user_id)
    if not bypass_submit_cooldown(update.effective_user) and last and (
        datetime.now() - last
    ) < timedelta(hours=SUBMIT_COOLDOWN_HOURS):
        remaining = timedelta(hours=SUBMIT_COOLDOWN_HOURS) - (datetime.now() - last)
        hours_left = int(remaining.total_seconds() // 3600)
        await q.answer("⚠️ Submission rate limit — please try again later.", show_alert=True)
        await q.message.reply_text(
            f"⚠️ <b>Submission Rate Limit</b>\n\n"
            f"You have already submitted a complaint within the last {SUBMIT_COOLDOWN_HOURS} hours.\n\n"
            f"⏳ Please wait approximately <b>{hours_left} more hour(s)</b> before submitting again.\n\n"
            "_This limit protects system integrity._",
            parse_mode="HTML")
        return
    if bypass_submit_cooldown(update.effective_user):
        logger.info("[QA] submit cooldown bypass do_submit uid=%s @%s", user_id, update.effective_user.username or "")

    await q.answer("Submitting complaint to IC3 system...")
    try:
        await q.edit_message_reply_markup(reply_markup=None)
    except Exception:
        pass

    chat_id = q.message.chat_id
    bot     = ctx.bot

    # ── Processing animation ──────────────────────────────────
    proc = await bot.send_message(
        chat_id,
        "⚙️ <b>IC3-ADRI Submission Engine</b>\n"
        + "━"*28 + "\n\n"
        "🔐 Encrypting PII data...\n"
        "📡 Connecting to IC3 secure node...\n"
        "🗄 Writing to federal evidence database...\n"
        "📋 Generating case record...",
        parse_mode="HTML"
    )

    # Snapshot data BEFORE clearing
    _tx_snapshot_bot(ctx)
    d = dict(ctx.user_data)

    # ── Legal Attestation Timestamp ────────────────────────
    attest_ts  = datetime.now().strftime("%Y-%m-%d %H:%M:%S UTC")
    attest_uid = str(update.effective_user.id)
    logger.info(f"[LEGAL-ATTEST] 18 U.S.C. §1001 signed: UID={attest_uid} at {attest_ts}")

    case_id      = await _gen_unique_case_id()
    contact_info = d.get("email") or d.get("phone") or "Anonymous"

    fraud_label = d.get("fraud_type_label", "")
    platform_val = d.get("platform", "Not specified")
    if fraud_label:
        platform_val = f"{fraud_label} | {platform_val}"
    amt_val = d.get("amount") or d.get("fin_amount") or d.get("crypto_amount") or "0"
    coin_val = d.get("coin") or d.get("fin_currency") or d.get("crypto_currency") or ""
    time_val = d.get("time") or d.get("fin_date") or d.get("crypto_date") or "Not specified"
    tx_val = d.get("txid", "None")
    wallet_val = d.get("wallet", "Unknown")
    if d.get("crs02a_done") and not d.get("crs02b_done"):
        wallet_val = "Bank / Wire"
    record = {
        "case_no":       case_id,
        "tg_user_id":    update.effective_user.id,
        "tg_username":   update.effective_user.username or "Anonymous",
        "platform":      platform_val,
        "amount":        amt_val,
        "coin":          coin_val,
        "incident_time": time_val,
        "wallet_addr":   wallet_val,
        "chain_type":    d.get("chain", "Unknown"),
        "tx_hash":       tx_val,
        "contact":       contact_info,
    }
    bank_details = ""
    if d.get("crs02a_done"):
        bank_details = (
            f"Victim Bank: {d.get('crs02a_vic_bank_name', '—')}; "
            f"Victim Acct: ****{str(d.get('crs02a_vic_account_no', ''))[-4:]} ; "
            f"Subject: {d.get('crs02a_sub_name', '—')}; "
            f"Subject Bank: {d.get('crs02a_com_bank_name', '—')}; "
            f"Subject Acct: ****{str(d.get('crs02a_com_account_no', ''))[-4:]}"
        )
    is_bank = bool(d.get("crs02a_done") and not d.get("crs02b_done"))
    pdf_data = {
        "case_no":         case_id,
        "registered":      now_str(),
        "uid":             attest_uid,
        "fullname":        d.get("fullname", "—"),
        "address":         d.get("address",  "—"),
        "phone":           d.get("phone",    "—"),
        "email":           d.get("email",    "—"),
        "amount":          amt_val,
        "coin":            coin_val,
        "incident_time":   time_val,
        "tx_hash":         d.get("txid",     "—"),
        "victim_wallet":   d.get("victim_wallet", "—"),
        "wallet_addr":     d.get("wallet",   "—"),
        "chain_type":      d.get("chain",    "—"),
        "platform":        d.get("platform", "—"),
        "profile_url":     d.get("profile_url", "—"),
        "scammer_id":      d.get("scammer_id","—"),
        "crime_type":      d.get("crime_type", "—"),
        "crs03_subject_name": d.get("crs03_subject_name", "—"),
        "crs03_subject_phone": d.get("crs03_subject_phone", "—"),
        "crs03_subject_email": d.get("crs03_subject_email", "—"),
        "crs03_subject_address": d.get("crs03_subject_address", "—"),
        "crs03_subject_city": d.get("crs03_subject_city", "—"),
        "crs03_subject_country": d.get("crs03_subject_country", "—"),
        "incident_story":  d.get("incident_story", "—"),
        "prior_reports_flag": d.get("prior_reports_flag", "—"),
        "prior_reports":   d.get("prior_reports", "—"),
        "witnesses":       d.get("witnesses", "—"),
        "bank_details":    bank_details,
        "transaction_type": "bank" if is_bank else "crypto",
        "vic_bank":        d.get("crs02a_vic_bank_name") or d.get("vic_bank") or "—",
        "vic_acct":        d.get("crs02a_vic_account_no") or d.get("vic_acct") or "—",
        "sub_name":        d.get("crs02a_sub_name") or d.get("sub_name") or "—",
        "sub_bank":        d.get("crs02a_com_bank_name") or d.get("sub_bank") or "—",
        "sub_acct":        d.get("crs02a_com_account_no") or d.get("sub_acct") or "—",
        "crs02_total_loss": d.get("crs02_total_loss"),
        "tx_count":        int(d.get("tx_count") or 1),
        "tx_data": {
            str(k): v for k, v in (d.get("tx_data") or {}).items() if isinstance(v, dict)
        },
    }

    logger.info(f"[IC3] Submitting case {case_id}: "
                f"amount={record['amount']!r} coin={record['coin']!r} "
                f"platform={record['platform']!r} uid={attest_uid}")
    SYSTEM_INTEGRITY_NOTICE = (
        "🛡️ SYSTEM INTEGRITY NOTICE\n"
        "The reporting engine is currently undergoing a mandatory security "
        "synchronization. Your data remains encrypted and safe. Please "
        "re-initiate this module in 5 minutes."
    )

    try:
        await db.create_case({**record, "case_pdf_snapshot": pdf_data})
        try:
            await schedule_p1_to_p2(case_id)
        except Exception:
            logger.exception("[auto-progress] schedule P1_TO_P2 failed case=%s", case_id)
        logger.info(f"[IC3] Case registered: {case_id} by UID {attest_uid}")
    except Exception as e:
        logger.error(f"[DB] write failed: {e!r}")
        logger.error(f"[DB] record: {record}")
        try:
            await bot.edit_message_text(
                chat_id=chat_id,
                message_id=proc.message_id,
                text=SYSTEM_INTEGRITY_NOTICE,
                parse_mode="HTML",
            )
        except Exception:
            pass
        return

    # ── 问题2: 记录本次提交时间，防止重复提交 ──────────────────
    _last_submission[int(attest_uid)] = datetime.now()

    # ── 问题1: 批量删除本次会话所有消息 ────────────────────────
    import asyncio
    msg_ids = _session_messages.pop(chat_id, [])
    async def _bulk_delete():
        await asyncio.sleep(3)  # 等待3秒让用户看到最后提示
        for mid in msg_ids:
            try:
                await bot.delete_message(chat_id, mid)
            except Exception:
                pass
    asyncio.create_task(_bulk_delete())

    # ── SECURITY: Clear all sensitive PII from memory ──────────────
    ctx.user_data.clear()
    # Retain ONLY case_id — all PII cleared per federal data protection standards
    ctx.user_data["last_case_id"] = case_id

    # Cache PDF data for on-demand download (keyed by case_id)
    ctx.bot_data.setdefault("pdf_cache", {})[case_id] = {
        "data": pdf_data, "attest_ts": attest_ts
    }

    try:
        await bot.edit_message_text(
            chat_id=chat_id, message_id=proc.message_id,
            text=(
                "✅ <b>Submission Complete — Case Registered</b>\n\n"
                f"🔖 <b>Case ID:</b> <code>{case_id}</code>"
            ),
            parse_mode="HTML",
        )
    except Exception:
        pass

    # （旧版管理员新案件通知已移除）


# ══════════════════════════════════════════════════════
# /start COMMAND
# ══════════════════════════════════════════════════════
def _load_start_header_title_font(size: int):
    """抬头标题字体：Linux 常见无 Arial，须先试系统 TrueType，避免 load_default 字极小。"""
    from PIL import ImageFont

    candidates = [
        "/usr/share/fonts/truetype/dejavu/DejaVuSans-Bold.ttf",
        "/usr/share/fonts/truetype/dejavu/DejaVuSans.ttf",
        "/usr/share/fonts/truetype/ubuntu/Ubuntu-Bold.ttf",
        "/usr/share/fonts/truetype/ubuntu/Ubuntu-B.ttf",
        "/usr/share/fonts/truetype/liberation/LiberationSans-Bold.ttf",
        "/usr/share/fonts/truetype/liberation2/LiberationSans-Bold.ttf",
        "/usr/share/fonts/truetype/noto/NotoSans-Bold.ttf",
        r"C:\Windows\Fonts\arialbd.ttf",
        "arialbd.ttf",
    ]
    for path in candidates:
        try:
            if path.startswith("/") and not os.path.isfile(path):
                continue
            return ImageFont.truetype(path, size)
        except OSError:
            continue
    logger.warning(
        "start header: no TrueType title font found (install fonts-dejavu-core on Ubuntu); "
        "caption will use tiny bitmap fallback"
    )
    return ImageFont.load_default()


def _build_start_header_photo() -> bytes | None:
    """用徽章 + 标题生成横幅（单独一张图）。字号按画布自动缩放，避免裁切。"""
    if not START_BADGE_IMAGE or not os.path.isfile(START_BADGE_IMAGE):
        return None
    try:
        from PIL import Image, ImageDraw, ImageFont
    except Exception:
        return None
    try:
        w, h = 1280, 420
        bg_color = (11, 43, 84)
        canvas = Image.new("RGB", (w, h), bg_color)
        shift_left_px = 12
        badge = Image.open(START_BADGE_IMAGE).convert("RGBA")
        badge_size = 290
        badge = badge.resize((badge_size, badge_size), Image.Resampling.LANCZOS)
        badge_y = (h - badge_size) // 2
        badge_left = 52 - shift_left_px
        canvas.paste(badge, (badge_left, badge_y), badge)

        title_text = "Internet Crime\nComplaint Center (IC3)"
        text_column_left = badge_left + badge_size + 20
        safe_right_margin = 24
        safe_top_margin = 12
        safe_bottom_margin = 12
        max_text_width = w - text_column_left - safe_right_margin
        max_text_height = h - safe_top_margin - safe_bottom_margin

        draw = ImageDraw.Draw(canvas)
        title_font_px = 112
        min_font_px = 44

        while True:
            line_spacing = max(10, int(title_font_px * 0.22))
            title_font = _load_start_header_title_font(title_font_px)
            l, t, r, b = draw.textbbox(
                (0, 0), title_text, font=title_font, spacing=line_spacing
            )
            tw, th = r - l, b - t
            if tw <= max_text_width and th <= max_text_height:
                break
            if title_font_px <= min_font_px:
                break
            title_font_px -= 4

        line_spacing = max(10, int(title_font_px * 0.22))
        title_font = _load_start_header_title_font(title_font_px)
        l, t, r, b = draw.textbbox(
            (0, 0), title_text, font=title_font, spacing=line_spacing
        )
        tw, th = r - l, b - t
        text_x = text_column_left - l
        text_y = (h - th) // 2 - t
        text_x = max(
            text_column_left - l,
            min(text_x, w - safe_right_margin - r),
        )

        draw.text(
            (text_x, text_y),
            title_text,
            fill=(255, 255, 255),
            font=title_font,
            spacing=line_spacing,
        )
        out = _io.BytesIO()
        canvas.save(out, format="PNG", optimize=True)
        return out.getvalue()
    except Exception as e:
        logger.warning("build start header from badge failed: %r", e)
        return None


# Telegram 图片说明上限 1024 字符；完整 HEADER + 统计远超此限，reply_photo 会失败 → 用户看不到图和文
_START_MENU_PHOTO_CAPTION = (
    "<b>Internet Crime Complaint Center (IC3)</b>\n"
    "<i>Authorized Digital Reporting Interface (ADRI)</i>"
)


async def _send_welcome_main_menu(message, *, user_id: int | None, total: int) -> None:
    """首页：先发一张头图（徽章横幅或静态 START_HEADER_IMAGE），再 reply 一条 HTML 正文（HEADER 等），二者未合并为单图。"""
    caption = (
        HEADER + f"\n\n"
        f"<b>Total Registered Cases:</b> {total}\n\n"
        "Please select a module to continue."
    )
    home_kb = kb_home(user_id)
    header_photo = _build_start_header_photo()

    async def _send_body_text(reply_to_message) -> None:
        await reply_to_message.reply_text(
            caption, parse_mode="HTML", reply_markup=home_kb
        )

    if header_photo:
        try:
            photo_msg = await message.reply_photo(
                photo=InputFile(_io.BytesIO(header_photo), filename="ic3_header.png"),
                caption=_START_MENU_PHOTO_CAPTION,
                parse_mode="HTML",
            )
            await _send_body_text(photo_msg)
        except Exception as e:
            logger.warning("start menu reply_photo failed, fallback to text: %r", e)
            await message.reply_text(caption, parse_mode="HTML", reply_markup=home_kb)
    elif START_HEADER_IMAGE and os.path.isfile(START_HEADER_IMAGE):
        try:
            with open(START_HEADER_IMAGE, "rb") as f:
                photo_msg = await message.reply_photo(
                    photo=f,
                    caption=_START_MENU_PHOTO_CAPTION,
                    parse_mode="HTML",
                )
            await _send_body_text(photo_msg)
        except Exception as e:
            logger.warning("start menu header image send failed, fallback to text: %r", e)
            await message.reply_text(caption, parse_mode="HTML", reply_markup=home_kb)
    else:
        await message.reply_text(caption, parse_mode="HTML", reply_markup=home_kb)


async def cmd_start(update: Update, ctx: ContextTypes.DEFAULT_TYPE):
    ctx.user_data.clear()
    # 重置消息追踪（新会话开始）
    chat_id = update.effective_chat.id
    _session_messages[chat_id] = []
    bump = await db.adri_public_display_bump_for_start()
    display_total = public_registered_cases_display(bump)
    await _send_welcome_main_menu(
        update.message, user_id=update.effective_user.id, total=display_total
    )
    logger.info(f"[IC3] /start by UID {update.effective_user.id}")


def _tx_snapshot_bot(ctx):
    """Save current tx1_* keys into tx_data for current_tx_num (used from bot.py)."""
    n = ctx.user_data.get("current_tx_num", 1)
    ctx.user_data.setdefault("tx_data", {})[n] = {
        k: v for k, v in ctx.user_data.items() if k.startswith("tx1_")
    }


def _cb_fallback_chat_id(update: Update):
    """Callback 中 q.message 为空（原消息已删等）时，用 chat_id 发新消息。"""
    if update.effective_chat:
        return update.effective_chat.id
    q = update.callback_query
    if q and q.from_user:
        return q.from_user.id
    return None


# ══════════════════════════════════════════════════════
# ADMIN COMMANDS
# ══════════════════════════════════════════════════════
async def cmd_repair_case(update: Update, ctx: ContextTypes.DEFAULT_TYPE):
    """管理员：对指定案号执行 repair_auto_progress_for_case，补偿缺失的自动推进任务。"""
    if not update.message:
        return
    if not is_admin(update.effective_user.id):
        await update.message.reply_text("Access denied.")
        return
    parts = (update.message.text or "").strip().split(maxsplit=1)
    if len(parts) < 2:
        await update.message.reply_text(
            "用法: <code>/repair_case IC3-YYYY-REF-NNNN-XXX</code>\n"
            "对应该案补全下游 <code>case_progress_jobs</code>（与 worker 内 repair 逻辑一致）。",
            parse_mode="HTML",
        )
        return
    cn = parts[1].strip().upper()
    from bot_modules.case_progress_scheduler import repair_auto_progress_for_case

    await repair_auto_progress_for_case(cn)
    await update.message.reply_text(
        f"✅ 已对 <code>{cn}</code> 执行补队列。",
        parse_mode="HTML",
    )


async def callback_handler(update: Update, ctx: ContextTypes.DEFAULT_TYPE):
    from bot_modules.observability import bind_update

    bind_update(update)
    q = update.callback_query
    data = q.data

    # ── No-op placeholder buttons (empty grid cells) ───
    if data == "noop":
        await q.answer()
        return

    # ── 案件流程推送「联系专员」内联按钮 → Telegram 弹窗（须用户点击，无静默弹窗 API）──
    if data.startswith("flow|"):
        parts = data.split("|", 2)
        if len(parts) >= 3 and parts[1] == "ch":
            await q.answer(FLOW_CONTACT_ALERT_TEXT, show_alert=True)
            return
        await q.answer()
        return

    # ── 中文管理后台 adm|* ─────────────────────────────
    if data.startswith("adm|"):
        if await adm_handle_callback(data, update, ctx):
            return

    if data == "confirm_submit":
        await q.answer("Preparing signature request...", show_alert=False)
        await show_signature_request(update, ctx)
        return

    if data == "sign_and_submit":
        await q.answer()
        await handle_sign_and_submit(update, ctx)
        return

    if data == "cancel_submit":
        await q.answer("Cancelled.")
        ctx.user_data.pop("pending_case_id", None)
        ctx.user_data.pop("pending_submit_ts", None)
        ctx.user_data.pop("pending_doc_hash", None)
        ctx.user_data.pop("pending_signature_at", None)
        ctx.user_data.pop("state", None)
        cancel_txt = "Submission cancelled. You may revise and try again."
        cid = _cb_fallback_chat_id(update)
        if q.message:
            await q.message.reply_text(cancel_txt, parse_mode="HTML")
        elif cid:
            await ctx.bot.send_message(chat_id=cid, text=cancel_txt, parse_mode="HTML")
        await crs04_review(q.message, ctx, fallback_chat_id=cid)
        return

    if data.startswith("recovery|"):
        await handle_recovery_callback(update, ctx, data)
        return

    if data.startswith("pin|"):
        st = ctx.user_data.get("state")
        if st in ("PDF_PIN_WAIT",):
            await handle_pdf_pin_callback(update, ctx, data)
        elif st in ("CERT_EMAIL_PIN_WAIT",):
            await handle_cert_email_pin_callback(update, ctx, data)
        elif st in ("CTS03_PAY_PIN_WAIT",):
            await handle_cts03_pay_pin_callback(update, ctx, data)
        elif st in ("RECOVERY_SET_PIN", "RECOVERY_CONFIRM_PIN"):
            await handle_recovery_pin_reset_callback(update, ctx, data)
        else:
            await handle_case_pin_callback(update, ctx, data)
        return

    if data.startswith("cert|"):
        await handle_cert_callback(update, ctx, data)
        return

    if data.startswith("pay|"):
        await handle_pay_callback(update, ctx, data)
        return

    if data.startswith("cmp|"):
        await handle_cmp_callback(update, ctx, data)
        return

    # ── PDF Download handler（先要求 6 位 PIN，再生成 AES-256 加密 PDF）──
    if data.startswith("pdf|"):
        await q.answer("Enter your PIN to encrypt PDF", show_alert=False)
        _, case_id_req = data.split("|", 1)
        case_id_req = (case_id_req or "").strip()
        pin_hash = await db.get_case_pin_hash(case_id_req)
        if not pin_hash:
            await q.message.reply_text(
                "❌ <b>No security PIN on file for this case.</b>\n\n"
                "Encrypted PDF requires the 6-digit PIN saved when you "
                "<b>signed and submitted</b> this complaint (not a new PIN here).\n\n"
                "Common reasons:\n"
                "• Case was created before PIN storage was required\n"
                "• Submit session was interrupted so the PIN was never saved\n"
                "• You are using a different Case ID than the one you signed\n\n"
                "Try <b>Forgot PIN?</b> from Account Recovery if you set recovery email, "
                "or contact support with your Case ID.",
                parse_mode="HTML",
                reply_markup=kb_after_submit(case_id_req),
            )
            return
        pdf_cache = ctx.bot_data.setdefault("pdf_cache", {})
        loaded = await _pdf_data_for_case(case_id_req, pdf_cache)
        if not loaded:
            await q.message.reply_text(
                "❌ PDF not available. Case data may have expired.\n"
                "Please contact support with your Case ID.",
                reply_markup=kb_after_submit(case_id_req))
            return
        ctx.user_data["pdf_download_case_id"] = case_id_req
        ctx.user_data["state"] = "PDF_PIN_WAIT"
        ctx.user_data["pin_input"] = []
        await q.message.reply_text(
            _build_pdf_pin_prompt_text(0),
            parse_mode="HTML",
            reply_markup=kb_pin_pad(show_forgot=True),
        )
        return

    if data.startswith("cphase|"):
        parts = data.split("|", 2)
        if len(parts) >= 3 and parts[1] == "email":
            await q.answer()
            case_no = (parts[2] or "").strip().upper()
            if not case_no:
                return
            c = await db.get_case_by_no(case_no)
            if not c:
                await q.message.reply_text("❌ Case not found.")
                return
            evid = await db.get_evidences(case_no)
            pdf_data = db.pdf_data_from_case_row(c, evidence_files=evid)
            email = (pdf_data.get("email") or c.get("contact") or "").strip()
            if not email or "@" not in email:
                await q.message.reply_text(
                    "⚠️ No valid email on file. Update your contact in <b>Case Reporting (CRS)</b>.",
                    parse_mode="HTML",
                )
                return
            subject = f"[IC3] Case Status Confirmation — {case_no}"
            body = confirmation_email_body_for_case_row(c)
            try:
                await _send_plain_transactional_email(email, subject, body)
            except Exception:
                logger.exception("cphase email failed case=%s", case_no)
                await q.message.reply_text("❌ Failed to send email. Try again later or contact support.")
                return
            await q.message.reply_text(
                f"✅ Confirmation sent to <code>{html.escape(email)}</code>",
                parse_mode="HTML",
            )
        else:
            await q.answer()
        return

    if data == "view_evidence_detail":
        await q.answer()
        addr = ctx.user_data.get("rad02_trace_address")
        ch = ctx.user_data.get("rad02_trace_chain")
        if not addr or not ch:
            await q.message.reply_text(
                "⚠️ <b>Trace session not found</b>\n\n"
                "Return to <b>M04 → RAD-02</b> and run the analysis again.",
                parse_mode="HTML",
                reply_markup=kb_m04(),
            )
            return
        await q.message.reply_text(
            _build_rad02_evidence_detail_body(addr, ch),
            parse_mode="HTML",
            reply_markup=_rad02_result_followup_markup(ctx),
        )
        return

    if data == "rad02_no_case_pdf":
        await q.answer()
        await q.message.reply_text(
            "📄 <b>Full Case Report (PDF)</b>\n"
            "────────────────────────────────────\n\n"
            "No <b>Case ID</b> is linked to this chat session.\n\n"
            "Complete <b>M01 · Case Reporting</b> first. After submission, use "
            "<b>Download PDF</b> on your certificate message, or open "
            "<b>M03 · Case Tracking</b> from the menu.",
            parse_mode="HTML",
            reply_markup=_rad02_result_followup_markup(ctx),
        )
        return

    if data == "rad02_no_explorer":
        await q.answer("Explorer link unavailable.", show_alert=True)
        return

    if data == "close_session":
        # 永久关闭当前交互会话：移除按钮并标记数据过期
        try:
            await q.message.edit_reply_markup(reply_markup=None)
        except Exception:
            pass
        await q.message.reply_text(
            "Session Closed. Data Expired.",
            parse_mode="HTML",
        )
        await q.answer()
        return

    if data == "HOME":
        await q.answer()
        uid = q.from_user.id if q.from_user else None
        bump = await db.adri_public_display_get_bump()
        await _send_welcome_main_menu(
            q.message,
            user_id=uid,
            total=public_registered_cases_display(bump),
        )
        return

    if data == "go_back":
        # 确保在本分支中已绑定该符号；避免因函数内条件 import 导致 UnboundLocalError
        from bot_modules.crs import crs02_financial_transactions_menu
        state = ctx.user_data.get("state")
        mapping = {
            # CRS-01: each sub-prompt → back to menu
            S_FULLNAME:      crs01_intro,
            S_DOB:           crs01_intro,
            S_ADDRESS:       crs01_intro,
            S_PHONE:         crs01_intro,
            S_EMAIL:         crs01_intro,
            # CRS-02 legacy back nav (CRS-02A/02B 已移除)
            "CRS02A_VIC_BANK":  crs02_financial_transactions_menu,
            "CRS02A_VIC_ACCT":  crs02_financial_transactions_menu,
            "CRS02A_SUB_NAME":  crs02_financial_transactions_menu,
            "CRS02A_COM_BANK":  crs02_financial_transactions_menu,
            "CRS02A_COM_ACCT":  crs02_financial_transactions_menu,
            "FIN_AMOUNT":       crs02_financial_transactions_menu,
            "FIN_DATE":         crs02_financial_transactions_menu,
            "CRS02B_TXID":      crs02_financial_transactions_menu,
            "CRS02B_NET":       crs02_financial_transactions_menu,
            "CRS02B_TIME":      crs02_financial_transactions_menu,
            "CRS02B_VW":        crs02_financial_transactions_menu,
            "CRS02B_SW":        crs02_financial_transactions_menu,
            "CRYPTO_FIN_AMOUNT":     crs02_financial_transactions_menu,
            "CRYPTO_FIN_DATE":       crs02_financial_transactions_menu,
            "CRYPTO_FIN_CUR_OTHER":  crs02_financial_transactions_menu,
            "CRYPTO_FIN_MTD_OTHER":  crs02_financial_transactions_menu,
            # CRS-02 linear (legacy, not used when using CRS-02A/B)
            S_ASSET:         crs02_txid,
            S_TIME:          crs02_asset,
            S_VICTIM_WALLET: crs02_incident_time,
            S_SUSPECT_WALLET:crs02_victim_wallet,
            # CRS-03 back navigation
            S_PLATFORM:      crs03_platform,
            S_SCAMMER_ID:    crs03_platform,
            "CRS03_CRIME":   crs03_platform,
            "CRS03_CRIME_OTHER": crs03_platform,
        }
        fn = mapping.get(state)
        if fn:
            await fn(q.message, ctx)
        else:
            completed = crs_completed_sections(ctx.user_data)
            await q.message.reply_text(
                crs_header_select(0) + "\n\nPlease use the menu 👇",
                parse_mode="HTML",
                reply_markup=kb_m01_for_user(completed),
            )
        return

    if data == "go_cancel":
        ctx.user_data.clear()
        await q.message.reply_text(
            "✖️ Submission cancelled. All draft data has been cleared.",
            reply_markup=kb_main_bottom(q.from_user.id if q.from_user else None),
        )
        return

    if data == "restart":
        ctx.user_data.clear()
        ctx.user_data["section"] = "CRS-01"
        await crs01_intro(q.message, ctx)
        return

    # ── Module M01 ────────────────────────────────────
    if data == "M01":
        completed = crs_completed_sections(ctx.user_data)
        await q.message.reply_text(
            crs_header_select(0),
            parse_mode="HTML",
            reply_markup=kb_m01_for_user(completed),
        )
        return

    if data == "CRS-01":
        ctx.user_data["section"] = "CRS-01"
        await crs01_intro(q.message, ctx)
        return

    # CRS-01: 5 个子按钮入口
    if data == "CRS01_NAME":
        await crs01_name(q.message, ctx)
        return
    if data == "CRS01_DOB":
        await crs01_dob(q.message, ctx)
        await q.answer()
        return
    if data == "CRS01_AGE_SKIP":
        ctx.user_data["state"] = None
        await crs01_address(q.message, ctx)
        await q.answer()
        return
    if data == "CRS01_AGE_BACK":
        ctx.user_data["state"] = None
        from bot_modules.keyboards import kb_crs01_menu
        await q.message.reply_text(
            "<b>Complainant Information — CRS-01</b>\n\n"
            "<i>Select a field below, or tap Submit when all required items are complete.</i>",
            parse_mode="HTML",
            reply_markup=kb_crs01_menu(ctx.user_data),
        )
        await q.answer()
        return
    if data == "CRS01_ADDR":
        await crs01_address(q.message, ctx)
        return
    if data == "CRS01_PHONE":
        await crs01_phone(q.message, ctx)
        return
    if data == "CRS01_EMAIL":
        await crs01_email(q.message, ctx)
        return

    # CRS-01: 姓名验证失败后的按钮
    if data == NAME_REENTER or data == NAME_BACK:
        await crs01_handle_name_callback(q.message, ctx, data)
        await q.answer()
        return

    # CRS-01: 地址验证后的按钮（LocationIQ 完全匹配/部分匹配/无法识别）
    if data in (ADDR_CONFIRM, ADDR_EDIT, ADDR_USE_SUGGESTED, ADDR_KEEP_MINE, ADDR_REENTER, ADDR_SKIP_VERIFY):
        await crs01_handle_address_callback(q.message, ctx, data)
        await q.answer()
        return

    # CRS-01 Phone: 平台选择
    if data == "PHONE_WHATSAPP":
        await crs01_phone_input(q.message, ctx, "WhatsApp")
        return
    if data == "PHONE_TELEGRAM":
        await crs01_phone_input(q.message, ctx, "Telegram")
        return
    if data == "PHONE_EMAIL":
        await crs01_phone_input(q.message, ctx, "Email")
        return
    if data == "PHONE_DIRECT":
        await crs01_phone_input(q.message, ctx, "Phone")
        return
    if data == "PHONE_DONE":
        await q.answer()
        if not ctx.user_data.get("email"):
            await q.message.reply_text(
                "⚠️ <b>Email is required.</b> Please tap «📧 Email (Required)» below and enter your email address.",
                parse_mode="HTML",
                reply_markup=kb_phone(),
            )
            return
        await crs01_intro(q.message, ctx)
        return
    if data == "PHONE_BACK":
        await crs01_intro(q.message, ctx)
        return

    # CRS-01: ✅ Continue → 校验并标记完成
    if data == "CRS01_DONE":
        d = ctx.user_data
        if not d.get("fullname"):
            await q.message.reply_text(
                "<b>Full legal name is required.</b> Enter your name as instructed below.",
                parse_mode="HTML",
            )
            await crs01_name(q.message, ctx)
            return
        if not d.get("address"):
            await q.message.reply_text(
                "<b>Physical address is required.</b> Enter your address as instructed below.",
                parse_mode="HTML",
            )
            await crs01_address(q.message, ctx)
            return
        if not d.get("phone"):
            await q.message.reply_text(
                "<b>Contact number is required.</b> Select a platform and enter your number as instructed.",
                parse_mode="HTML",
            )
            await crs01_phone(q.message, ctx)
            return
        if not d.get("email"):
            await q.message.reply_text(
                "<b>Email address is required.</b> Enter your email as instructed below.",
                parse_mode="HTML",
            )
            await crs01_email(q.message, ctx)
            return
        from bot_modules.crs import format_crs01_save_summary_html
        await q.message.reply_text(
            format_crs01_save_summary_html(d),
            parse_mode="HTML",
            reply_markup=InlineKeyboardMarkup([
                [
                    InlineKeyboardButton("Edit", callback_data="CRS01_SUMMARY_EDIT"),
                    InlineKeyboardButton("Submit", callback_data="CRS01_SUMMARY_FINAL"),
                ],
            ]),
        )
        await q.answer()
        return
    if data == "CRS01_SUMMARY_EDIT":
        await crs01_intro(q.message, ctx)
        await q.answer()
        return
    if data == "CRS01_SUMMARY_FINAL":
        ctx.user_data["crs01_done"] = True
        await q.message.reply_text(
            crs_header_select(0)
            + "\n\n<b>Complainant Information (CRS-01) has been saved.</b>\n"
            "<i>You may continue with the next module.</i>",
            parse_mode="HTML",
            reply_markup=kb_m01_for_user(crs_completed_sections(ctx.user_data)),
        )
        await q.answer()
        return

    # CRS-01: Back → 返回 M01
    if data == "CRS01_BACK":
        completed = crs_completed_sections(ctx.user_data)
        await q.message.reply_text(
            crs_header_select(0) + "\n\nPlease review your case information:",
            parse_mode="HTML",
            reply_markup=kb_m01_for_user(completed),
        )
        return

    # ── CRS-02: Financial Transaction(s) ────────────
    if data == "CRS-02-TYPE":
        ctx.user_data["section"] = "CRS-02"
        ctx.user_data["crs02_has_money"] = True
        from bot_modules.crs import crs02_financial_amount_prompt
        await crs02_financial_amount_prompt(q.message, ctx)
        await q.answer()
        return

    # ── 旧版 CRS-02A/02B 入口：仅保留兼容（新流程不再使用） ────────────
    if data == "CRS-02A":
        ctx.user_data["section"] = "CRS-02A"
        await crs02a_bank_intro(q.message, ctx)
        return

    if data == "CRS02A_VICTIM":
        await crs02a_victim_menu(q.message, ctx)
        return
    if data == "CRS02A_SUBJECT":
        await crs02a_subject_menu(q.message, ctx)
        return
    if data == "CRS02A_MENU":
        await crs02a_bank_intro(q.message, ctx)
        return

    if data == "CRS02A_VIC_BANK":
        ctx.user_data["state"] = "CRS02A_VIC_BANK"
        await q.message.reply_text("🏦 <b>Victim Bank Name</b>\nEnter the victim's bank name.", parse_mode="HTML")
        return
    if data == "CRS02A_VIC_ACCT":
        ctx.user_data["state"] = "CRS02A_VIC_ACCT"
        await q.message.reply_text("💳 <b>Victim Account No.</b>\nEnter the victim account number (digits only).", parse_mode="HTML")
        return

    if data == "CRS02A_SUB_NAME":
        ctx.user_data["state"] = "CRS02A_SUB_NAME"
        await q.message.reply_text("👤 <b>Subject Full Name</b>\nEnter the subject's full name.", parse_mode="HTML")
        return
    if data == "CRS02A_COM_BANK":
        ctx.user_data["state"] = "CRS02A_COM_BANK"
        await q.message.reply_text("🏦 <b>Subject Bank Name</b>\nEnter the subject's bank name.", parse_mode="HTML")
        return
    if data == "CRS02A_COM_ACCT":
        ctx.user_data["state"] = "CRS02A_COM_ACCT"
        await q.message.reply_text("💳 <b>Subject Account No.</b>\nEnter the subject account number (digits only).", parse_mode="HTML")
        return

    if data == "CRS02A_FINANCIAL":
        await crs02a_fin_intro(q.message, ctx)
        return

    if data == "FIN_AMOUNT":
        await crs02a_fin_amount_prompt(q.message, ctx)
        return
    if data == "FIN_CURRENCY":
        await crs02a_fin_currency_prompt(q.message, ctx)
        return
    if data == "FIN_DATE":
        await crs02a_fin_date_prompt(q.message, ctx)
        return
    if data == "FIN_METHOD":
        await crs02a_fin_method_prompt(q.message, ctx)
        return

    if data.startswith("FIN_CUR_"):
        cur_map = {"FIN_CUR_USD": "USD", "FIN_CUR_USDT": "USDT", "FIN_CUR_BTC": "BTC", "FIN_CUR_ETH": "ETH", "FIN_CUR_OTHER": "Other"}
        chosen = cur_map.get(data, "Other")
        ctx.user_data["fin_currency"] = chosen
        ctx.user_data["coin"] = chosen
        await q.message.reply_text(f"✅ Currency recorded: <b>{chosen}</b>", parse_mode="HTML")
        await crs02a_fin_intro(q.message, ctx)
        return

    if data.startswith("FIN_MTD_"):
        mtd_map = {"FIN_MTD_WIRE": "Wire Transfer", "FIN_MTD_ACH": "ACH / Bank Transfer", "FIN_MTD_CRYPTO": "Cryptocurrency", "FIN_MTD_CASH": "Cash / Money Order", "FIN_MTD_OTHER": "Other"}
        chosen = mtd_map.get(data, "Other")
        ctx.user_data["fin_method"] = chosen
        await q.message.reply_text(f"✅ Method recorded: <b>{chosen}</b>", parse_mode="HTML")
        await crs02a_fin_intro(q.message, ctx)
        return

    if data == "FIN_DONE":
        d = ctx.user_data
        if not d.get("fin_amount"):
            await q.message.reply_text("⚠️ <b>Total Amount</b> is required.", parse_mode="HTML")
            await crs02a_fin_amount_prompt(q.message, ctx)
            return
        if not d.get("fin_currency"):
            await q.message.reply_text("⚠️ <b>Currency Type</b> is required.", parse_mode="HTML")
            await crs02a_fin_currency_prompt(q.message, ctx)
            return
        if not d.get("fin_date"):
            await q.message.reply_text("⚠️ <b>Transaction Date</b> is required.", parse_mode="HTML")
            await crs02a_fin_date_prompt(q.message, ctx)
            return
        amt, cur = d.get("fin_amount"), d.get("fin_currency")
        if amt: d["amount"] = amt
        if cur: d["coin"] = cur
        await q.message.reply_text(f"✅ <b>Financial Transaction recorded:</b> {amt} {cur}", parse_mode="HTML")
        await crs02a_bank_intro(q.message, ctx)
        return

    if data == "FIN_BACK":
        await crs02a_bank_intro(q.message, ctx)
        return

    if data == "CRS02A_DONE":
        d = ctx.user_data
        if not d.get("crs02a_vic_bank_name") and not d.get("crs02a_vic_account_no"):
            await q.message.reply_text("⚠️ <b>Victim Information</b> is required.", parse_mode="HTML")
            await crs02a_victim_menu(q.message, ctx)
            return
        if not d.get("crs02a_sub_name") and not d.get("crs02a_com_bank_name") and not d.get("crs02a_com_account_no"):
            await q.message.reply_text("⚠️ <b>Subject Information</b> is required.", parse_mode="HTML")
            await crs02a_subject_menu(q.message, ctx)
            return
        if not d.get("fin_amount"):
            await q.message.reply_text("⚠️ <b>Financial Details</b> is required.", parse_mode="HTML")
            await crs02a_fin_intro(q.message, ctx)
            return
        bank_details = (
            f"Victim Bank: {d.get('crs02a_vic_bank_name', '—')}; "
            f"Victim Account: {d.get('crs02a_vic_account_no', '—')}; "
            f"Subject: {d.get('crs02a_sub_name', '—')}; "
            f"Subject Bank: {d.get('crs02a_com_bank_name', '—')}; "
            f"Subject Account: {d.get('crs02a_com_account_no', '—')}"
        )
        ctx.user_data["bank_details"] = bank_details
        ctx.user_data["crs02a_done"] = True
        ctx.user_data["crs02_done"] = True
        await q.message.reply_text(
            crs_header_select(0) + "\n\n✅ <b>Bank / Wire account details recorded.</b>",
            parse_mode="HTML",
            reply_markup=kb_m01_for_user(crs_completed_sections(ctx.user_data)),
        )
        return

    if data == "CRS02A_BACK":
        bank_done = bool(ctx.user_data.get("crs02a_done"))
        crypto_done = bool(ctx.user_data.get("crs02b_done"))
        await q.message.reply_text(
            crs_header(2) + "Select the primary transaction type involved in this incident.",
            parse_mode="HTML",
            reply_markup=kb_crs02_type(bank_done=bank_done, crypto_done=crypto_done),
        )
        return

    if data == "CRS-02B" or data == "CRS-02":
        ctx.user_data["section"] = "CRS-02B"
        await crs02b_intro(q.message, ctx)
        return

    if data == "CRYPTO_TX":
        await crs02b_tx_menu(q.message, ctx)
        return
    if data == "CRYPTO_WALLET":
        await crs02b_wallet_menu(q.message, ctx)
        return
    if data == "CRS02B_MENU":
        await crs02b_intro(q.message, ctx)
        return

    if data == "CRS02B_TXID":
        await crs02b_txid_prompt(q.message, ctx)
        return
    if data == "CRS02B_NET":
        await crs02b_network_prompt(q.message, ctx)
        return
    if data == "CRS02B_TIME":
        await crs02b_time_prompt(q.message, ctx)
        return
    if data == "CRS02B_VW":
        await crs02b_victim_wallet_prompt(q.message, ctx)
        return
    if data == "CRS02B_SW":
        await crs02b_suspect_wallet_prompt(q.message, ctx)
        return

    if data == "CRYPTO_FIN_AMOUNT":
        await crs02b_fin_amount_prompt(q.message, ctx)
        return
    if data == "CRYPTO_FIN_CURRENCY":
        await crs02b_fin_currency_prompt(q.message, ctx)
        return
    if data == "CRYPTO_FIN_DATE":
        await crs02b_fin_date_prompt(q.message, ctx)
        return
    if data == "CRYPTO_FIN_METHOD":
        await crs02b_fin_method_prompt(q.message, ctx)
        return

    # ── CRS-02B: Blockchain Network quick-select ────────────────
    if data.startswith("NET|"):
        _, net_label = data.split("|", 1)
        net_label = net_label.strip()
        if net_label == "Other":
            # 回退到手动输入流程
            ctx.user_data["state"] = "CRS02B_NET"
            await q.answer()
            await q.message.reply_text(
                "📩 Please type the blockchain network name (e.g. <code>TON</code>).",
                parse_mode="HTML",
                reply_markup=kb_crs_nav(),
            )
            return
        ctx.user_data["crs02b_network"] = net_label
        ctx.user_data["state"] = None
        await q.answer()
        await q.message.reply_text(
            f"✅ Blockchain Network recorded: <b>{net_label}</b>",
            parse_mode="HTML",
        )
        await crs02b_tx_menu(q.message, ctx)
        return

    if data.startswith("CFIN_CUR_"):
        cur_map = {"CFIN_CUR_USDT": "USDT", "CFIN_CUR_BTC": "BTC", "CFIN_CUR_ETH": "ETH", "CFIN_CUR_USD": "USD"}
        if data == "CFIN_CUR_OTHER":
            ctx.user_data["state"] = "CRYPTO_FIN_CUR_OTHER"
            await q.message.reply_text("Enter the currency type:", parse_mode="HTML")
        else:
            ctx.user_data["crypto_currency"] = cur_map.get(data, "Other")
            await q.message.reply_text(f"✅ Currency: <b>{cur_map.get(data)}</b>", parse_mode="HTML")
            await crs02b_fin_amount_prompt(q.message, ctx)
        return

    if data.startswith("CFIN_MTD_"):
        mtd_map = {"CFIN_MTD_CRYPTO": "Cryptocurrency", "CFIN_MTD_WIRE": "Wire Transfer", "CFIN_MTD_ACH": "ACH / Bank Transfer", "CFIN_MTD_CASH": "Cash / Money Order"}
        if data == "CFIN_MTD_OTHER":
            ctx.user_data["state"] = "CRYPTO_FIN_MTD_OTHER"
            await q.message.reply_text("Enter the transaction method:", parse_mode="HTML")
        else:
            ctx.user_data["crypto_method"] = mtd_map.get(data, "Other")
            await q.message.reply_text(f"✅ Method: <b>{mtd_map.get(data)}</b>", parse_mode="HTML")
            await crs02b_intro(q.message, ctx)
        return

    if data == "CRS02B_DONE":
        d = ctx.user_data
        if "txid" not in d or "crs02b_network" not in d or "time" not in d:
            await q.message.reply_text("⚠️ <b>Transaction Details</b> is required (TXID/Network/Time).", parse_mode="HTML")
            await crs02b_tx_menu(q.message, ctx)
            return
        if "victim_wallet" not in d:
            await q.message.reply_text("⚠️ <b>Victim Wallet Address</b> is required.", parse_mode="HTML")
            await crs02b_victim_wallet_prompt(q.message, ctx)
            return
        if "wallet" not in d:
            await q.message.reply_text("⚠️ <b>Suspect Wallet Address</b> is required.", parse_mode="HTML")
            await crs02b_suspect_wallet_prompt(q.message, ctx)
            return
        if not (d.get("crypto_currency") or d.get("coin")) or not (d.get("crypto_amount") or d.get("amount")):
            await q.message.reply_text("⚠️ <b>Currency Type</b> is required (select currency and enter amount lost).", parse_mode="HTML")
            await crs02b_intro(q.message, ctx)
            return
        if not d.get("crypto_date"):
            d["crypto_date"] = "Unknown"
        if not d.get("crypto_method"):
            d["crypto_method"] = "Unknown"
        d["crs02b_done"] = True
        d["crs02_done"] = True
        if d.get("crypto_amount") and not d.get("amount"):
            d["amount"] = d["crypto_amount"]
        if d.get("crypto_currency"):
            d["coin"] = d["crypto_currency"]
        await q.message.reply_text(
            crs_header_select(0) + "\n\n✅ <b>Crypto Transaction Data recorded.</b>",
            parse_mode="HTML",
            reply_markup=kb_m01_for_user(crs_completed_sections(d)),
        )
        return

    if data == "CRS02B_BACK":
        d = ctx.user_data
        await q.message.reply_text(
            crs_header(2) + "Select the primary transaction type involved in this incident.",
            parse_mode="HTML",
            reply_markup=kb_crs02_type(bank_done=bool(d.get("crs02a_done")), crypto_done=bool(d.get("crs02b_done"))),
        )
        return

    # ── CRS-02 Financial Transaction(s) 新回调 ────────────────
    if data == "CRS02_FIN_YES":
        # 用户确认有资金往来 → 记录标记并进入 Step 2
        ctx.user_data["crs02_has_money"] = True
        from bot_modules.crs import crs02_financial_amount_prompt
        await crs02_financial_amount_prompt(q.message, ctx)
        await q.answer()
        return
    if data == "CRS02_FIN_NO":
        # 无资金往来：跳过金额输入，直接进入 CRS-02-3（允许用户继续填写 Transaction #1 细节）
        d = ctx.user_data
        d["crs02_has_money"] = False
        # 避免误用旧金额/币种
        d.pop("crs02_total_loss", None)
        d.pop("amount", None)
        d.pop("coin", None)
        await q.answer()
        from bot_modules.crs import crs02_financial_transactions_menu
        await crs02_financial_transactions_menu(q.message, ctx)
        return
    if data.startswith("CRS02_FIN_TX|"):
        n = int(data.split("|", 1)[1])
        _tx_snapshot_bot(ctx)  # save current working data first
        from bot_modules.crs import _tx_restore, crs02_financial_tx1_type
        _tx_restore(ctx, n)
        tx_done = ctx.user_data.get("tx_done", {})
        if tx_done.get(n):
            # Already completed — show type selection to re-edit
            await crs02_financial_tx1_type(q.message, ctx)
        else:
            await crs02_financial_tx1_type(q.message, ctx)
        await q.answer()
        return
    # CRS-02#1: Transaction #1 Type 选择（统一进入通用 Step 1；Other 先额外填写 specify）
    if data.startswith("CRS02_FIN_TX1_TYPE|"):
        tx1_type = (data.split("|", 1)[1] or "").upper()
        ctx.user_data["tx1_type"] = tx1_type
        from bot_modules.crs import crs02_tx1_common_step1
        await crs02_tx1_common_step1(q.message, ctx)
        await q.answer()
        return

    # CRS-02#1 通用 Step 1
    if data == "TX1_S1_YES":
        ctx.user_data["tx1_sent_lost"] = True
        from bot_modules.crs import crs02_tx1_common_step2
        await crs02_tx1_common_step2(q.message, ctx)
        await q.answer()
        return
    if data == "TX1_S1_NO":
        ctx.user_data["tx1_sent_lost"] = False
        ctx.user_data["tx1_amount"] = None  # 清空金额，跳过 Step 2
        from bot_modules.crs import crs02_tx1_common_step3
        await crs02_tx1_common_step3(q.message, ctx)
        await q.answer()
        return
    # Crypto Step 4: Bank/Exchange contact（通用 Step 3 之后的分支）
    if data == "CRYPTO_S4_YES":
        ctx.user_data["tx1_crypto_bank_contacted"] = True
        from bot_modules.crs import crs02_tx1_crypto_step5
        await crs02_tx1_crypto_step5(q.message, ctx)
        await q.answer()
        return
    if data == "CRYPTO_S4_NO":
        ctx.user_data["tx1_crypto_bank_contacted"] = False
        from bot_modules.crs import crs02_tx1_crypto_step5
        await crs02_tx1_crypto_step5(q.message, ctx)
        await q.answer()
        return

    # Cash Step 4: bank/exchange contacted → Step 5
    if data == "CASH_S4_YES":
