        "CRS03_P_TIKTOK":    "TikTok",    "CRS03_P_TWITTER":   "Twitter/X",
        "CRS03_P_YOUTUBE":   "YouTube",   "CRS03_P_LINKEDIN":  "LinkedIn",
        "CRS03_P_DISCORD":   "Discord",
    }
    if data in _C03_P_MAP:
